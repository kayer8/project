datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum VendorStatus {
  active
  disabled
}

enum BoothCategory {
  小吃
  饮品
  烧烤
  甜点
  水果
  百货
  其他
}

enum BoothStatus {
  offline
  operating
  abnormal
  pending
}

enum SessionStatus {
  running
  paused
  ended
  abnormal
}

enum AnomalyType {
  location_drift
  report_timeout
  manual_interrupt
}

enum AnomalyLevel {
  warning
  critical
}

enum FeedbackType {
  location_error
  info_error
  other
}

model User {
  id         BigInt         @id @default(autoincrement())
  nickname   String         @db.VarChar(50)
  avatar     String?        @db.VarChar(255)
  level      Int            @default(1)
  phone      String?        @db.VarChar(20)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  favorites  UserFavorite[]
  feedbacks  BoothFeedback[]
}

model Vendor {
  id         BigInt      @id @default(autoincrement())
  name       String      @db.VarChar(50)
  phone      String      @db.VarChar(20)
  status     VendorStatus
  created_at DateTime    @default(now())

  booths Booth[]
}

model Booth {
  id                   BigInt                 @id @default(autoincrement())
  vendor_id            BigInt
  vendor               Vendor                 @relation(fields: [vendor_id], references: [id])
  name                 String                 @db.VarChar(100)
  category             BoothCategory
  avatar               String?                @db.VarChar(255)
  description          String?                @db.Text
  show_contact         Boolean                @default(true)
  status               BoothStatus
  rating               Decimal                @db.Decimal(2, 1) @default(5.0)
  total_sessions       Int                    @default(0)
  total_duration_min   Int                    @default(0)
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt

  sessions             BoothSession[]
  locations            BoothLocation[]
  anomalies            BoothAnomaly[]
  favorites            UserFavorite[]
  favorite_locations   BoothFavoriteLocation[]
  feedbacks            BoothFeedback[]

  @@index([vendor_id])
  @@index([status])
}

model BoothSession {
  id                BigInt         @id @default(autoincrement())
  booth_id          BigInt
  booth             Booth          @relation(fields: [booth_id], references: [id])
  start_time        DateTime
  end_time          DateTime?
  status            SessionStatus
  start_lat         Decimal        @db.Decimal(10, 6)
  start_lng         Decimal        @db.Decimal(10, 6)
  start_address     String?        @db.VarChar(255)
  total_duration_min Int           @default(0)
  created_at        DateTime       @default(now())

  locations         BoothLocation[]
  anomalies         BoothAnomaly[]

  @@index([booth_id, status])
  @@index([start_time])
}

model BoothLocation {
  id          BigInt       @id @default(autoincrement())
  booth_id    BigInt
  booth       Booth        @relation(fields: [booth_id], references: [id])
  session_id  BigInt
  session     BoothSession @relation(fields: [session_id], references: [id])
  lat         Decimal      @db.Decimal(10, 6)
  lng         Decimal      @db.Decimal(10, 6)
  accuracy    Int
  reported_at DateTime
  created_at  DateTime     @default(now())

  @@index([booth_id, reported_at])
  @@index([session_id])
}

model BoothAnomaly {
  id           BigInt        @id @default(autoincrement())
  booth_id     BigInt
  booth        Booth         @relation(fields: [booth_id], references: [id])
  session_id   BigInt
  session      BoothSession  @relation(fields: [session_id], references: [id])
  type         AnomalyType
  level        AnomalyLevel
  description  String        @db.VarChar(255)
  detected_at  DateTime
  resolved_at  DateTime?
  resolved_by  BigInt?
  created_at   DateTime      @default(now())

  @@index([booth_id, detected_at])
  @@index([session_id])
}

model UserFavorite {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  user       User     @relation(fields: [user_id], references: [id])
  booth_id   BigInt
  booth      Booth    @relation(fields: [booth_id], references: [id])
  created_at DateTime @default(now())

  @@unique([user_id, booth_id])
  @@index([booth_id])
}

model BoothFavoriteLocation {
  id      BigInt  @id @default(autoincrement())
  booth_id BigInt
  booth   Booth   @relation(fields: [booth_id], references: [id])
  name    String  @db.VarChar(50)
  lat     Decimal @db.Decimal(10, 6)
  lng     Decimal @db.Decimal(10, 6)
  address String  @db.VarChar(255)
}

model BoothFeedback {
  id         BigInt        @id @default(autoincrement())
  booth_id   BigInt
  booth      Booth         @relation(fields: [booth_id], references: [id])
  user_id    BigInt
  user       User          @relation(fields: [user_id], references: [id])
  type       FeedbackType
  content    String        @db.Text
  created_at DateTime      @default(now())

  @@index([booth_id])
  @@index([user_id])
}
