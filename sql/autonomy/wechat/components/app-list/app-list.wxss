.km-list {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  width: 100%;
  height: 100%;
  min-height: 0;
}

.km-list__content {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  min-height: 0;
}

.km-list-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
}

.km-list-load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.km-list-finished {
  padding: 24rpx 0 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #86909c;
}

.km-list__loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200rpx;
}
