.page-body {
  padding: 24rpx 24rpx;
  background:
    radial-gradient(circle at top right, rgba(43, 90, 237, 0.08), transparent 34%),
    linear-gradient(180deg, #f4f7fb 0%, #eef3f8 100%);
  overflow: scroll;
}

.profile-section {
  margin-top: 24rpx;
}

.profile-section:first-child {
  margin-top: 0;
}

.profile-card,
.profile-header-card,
.profile-card2,
.profile-warning {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 48rpx rgba(31, 95, 191, 0.08);
}

.profile-card {
  padding: 28rpx;
}

.profile-card--menu {
  padding: 0;
}

.profile-card--guide {
  padding: 0;
  overflow: hidden;
}

.profile-header-card {
  padding: 30rpx 28rpx;
  background:
    linear-gradient(135deg, rgba(43, 90, 237, 0.1) 0%, rgba(255, 255, 255, 0.98) 42%, rgba(255, 255, 255, 0.98) 100%),
    #ffffff;
}

.profile-header__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-user {
  display: flex;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #d8e7ff 0%, #edf4ff 100%);
}

.profile-avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b5aed;
}

.profile-avatar__image {
  width: 100%;
  height: 100%;
}

.profile-user__content {
  min-width: 0;
  flex: 1;
}

.profile-user__role-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-user__role {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(43, 90, 237, 0.1);
  color: #2b5aed;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-user__house {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #42526b;
}

.profile-user__auth-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.profile-user__auth-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f7ff;
  color: #1f5fbf;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-user__mobile {
  font-size: 22rpx;
  color: #7b8798;
}

.profile-status {
  min-width: 112rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-status--success {
  background: #e9f7ef;
  color: #1f8a4d;
}

.profile-status--pending {
  background: #fff4e5;
  color: #c57a12;
}

.profile-section__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.profile-section__title {
  font-size: 31rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #172033;
}

.profile-section__desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7b8798;
}

.house-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7faff 0%, #f1f6fd 100%);
}

.house-card__content {
  flex: 1;
  min-width: 0;
}

.house-card__label {
  display: block;
  font-size: 22rpx;
  color: #7b8798;
}

.house-card__value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.45;
  color: #172033;
  font-weight: 700;
}

.house-card__actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.house-card__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 160rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.house-card__button--ghost {
  background: #ffffff;
  color: #2b5aed;
  border: 1px solid rgba(43, 90, 237, 0.14);
}

.house-card__button--primary {
  background: #2b5aed;
  color: #ffffff;
}

.guide-card {
  padding: 30rpx 28rpx;
  background:
    radial-gradient(circle at top right, rgba(43, 90, 237, 0.14), transparent 42%),
    linear-gradient(180deg, #f7faff 0%, #eff5ff 100%);
}

.guide-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(43, 90, 237, 0.12);
  color: #2b5aed;
  font-size: 22rpx;
  font-weight: 700;
}

.guide-card__title {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #172033;
}

.guide-card__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5d6b82;
}

.guide-card__button-wrap {
  margin-top: 24rpx;
}

.guide-card__button {
  width: 100%;
}

.guide-card__footer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.guide-card__hint {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8798;
}

.guide-card__link {
  font-size: 24rpx;
  font-weight: 600;
  color: #2b5aed;
}

.menu-list {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx;
  border-bottom: 1px solid #eef1f4;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item__left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
  flex: 1;
}

.menu-item__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.menu-item__title {
  min-width: 0;
  flex: 1;
  font-size: 30rpx;
  line-height: 1.45;
  color: #333;
  font-weight: 500;
}

.profile-warning {
  padding: 20rpx 22rpx;
  background: #fff7eb;
  color: #a16910;
  font-size: 23rpx;
  line-height: 1.65;
}

.profile-card--loading {
  display: flex;
  gap: 20rpx;
  padding: 28rpx;
}

.profile-loading__avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
  background: linear-gradient(90deg, #edf2f8 25%, #f7f9fc 50%, #edf2f8 75%);
  background-size: 200% 100%;
  animation: profile-shimmer 1.4s ease infinite;
}

.profile-loading__content {
  flex: 1;
}

.profile-loading__line {
  height: 24rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #edf2f8 25%, #f7f9fc 50%, #edf2f8 75%);
  background-size: 200% 100%;
  animation: profile-shimmer 1.4s ease infinite;
}

.profile-loading__line--title {
  width: 56%;
  height: 32rpx;
  margin-top: 8rpx;
}

.profile-loading__line--short {
  width: 38%;
}

.profile-mini-icon,
.profile-menu-icon {
  color: #333;
}

.profile-mini-icon--light {
  color: #ffffff;
}

@keyframes profile-shimmer {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}
