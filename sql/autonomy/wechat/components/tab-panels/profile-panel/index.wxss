.panel-refresh {
  display: block;
  height: 100%;
}

.page-body {
  box-sizing: border-box;
  min-height: 100%;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(43, 90, 237, 0.08), transparent 34%),
    linear-gradient(180deg, #f4f7fb 0%, #eef3f8 100%);
}

.profile-section {
  margin-top: 24rpx;
}

.profile-section:first-child {
  margin-top: 0;
}

.profile-card,
.profile-header-card,
.profile-card2,
.profile-warning {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 48rpx rgba(31, 95, 191, 0.08);
}

.profile-card {
  padding: 28rpx;
}

.profile-card--menu {
  padding: 0;
}

.profile-header-card {
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(43, 90, 237, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(243, 247, 255, 0.98) 100%);
}

.profile-header__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.profile-user {
  display: flex;
  gap: 20rpx;
  min-width: 0;
  flex: 1;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #dbe7ff 0%, #edf4ff 100%);
  box-shadow: inset 0 0 0 1px rgba(43, 90, 237, 0.06);
}

.profile-avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b5aed;
}

.profile-avatar__image {
  width: 100%;
  height: 100%;
}

.profile-user__content {
  flex: 1;
  min-width: 0;
}

.profile-user__house {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #172033;
  word-break: break-all;
}

.profile-user__meta {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  box-sizing: border-box;
}

.profile-chip--primary {
  background: rgba(43, 90, 237, 0.1);
  color: #2b5aed;
  font-weight: 600;
}

.profile-chip--muted {
  background: #f5f7fb;
  color: #6d7a8c;
}

.profile-payment-card {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}

.profile-payment-card--success {
  background: linear-gradient(135deg, #eef9f1 0%, #f7fcf8 100%);
}

.profile-payment-card--warning {
  background: linear-gradient(135deg, #fff5e8 0%, #fffaf4 100%);
}

.profile-payment-card--danger {
  background: linear-gradient(135deg, #fff0ef 0%, #fff8f7 100%);
}

.profile-payment-card--neutral {
  background: linear-gradient(135deg, #f5f7fb 0%, #fafbfd 100%);
}

.profile-payment__left {
  flex: 1;
  min-width: 0;
}

.profile-payment__label {
  font-size: 22rpx;
  color: #7b8798;
}

.profile-payment__headline {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #172033;
}

.profile-payment__desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5d6b82;
}

.profile-payment__right {
  min-width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  color: #172033;
}

.profile-payment__amount {
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 700;
}

.profile-payment__hint {
  font-size: 22rpx;
  color: #7b8798;
}

.profile-payment__arrow {
  color: #9aa6b5;
}

.guide-card {
  padding: 30rpx 28rpx;
  background:
    radial-gradient(circle at top right, rgba(43, 90, 237, 0.14), transparent 42%),
    linear-gradient(180deg, #f7faff 0%, #eff5ff 100%);
}

.guide-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(43, 90, 237, 0.12);
  color: #2b5aed;
  font-size: 22rpx;
  font-weight: 700;
}

.guide-card__title {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #172033;
}

.guide-card__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5d6b82;
}

.guide-card__button-wrap {
  margin-top: 24rpx;
}

.guide-card__button {
  width: 100%;
}

.guide-card__footer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.guide-card__hint {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8798;
}

.guide-card__link {
  font-size: 24rpx;
  font-weight: 600;
  color: #2b5aed;
}

.menu-list {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 42rpx 48rpx;
  border-bottom: 1px solid #eef1f4;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item__left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.menu-item__icon {
  color: #384353;
  line-height: 1;
}

.menu-item__title {
  font-size: 28rpx;
  color: #172033;
}

.profile-warning {
  padding: 22rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #d84f42;
  background: #fff7f6;
}

.profile-card--loading {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx 28rpx;
}

.profile-loading__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: linear-gradient(90deg, #edf2f8 0%, #f6f8fb 50%, #edf2f8 100%);
}

.profile-loading__content {
  flex: 1;
}

.profile-loading__line {
  height: 22rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #edf2f8 0%, #f6f8fb 50%, #edf2f8 100%);
}

.profile-loading__line--title {
  width: 54%;
  height: 28rpx;
  margin-top: 0;
}

.profile-loading__line--short {
  width: 42%;
}

.safe-bottom-space {
  height: 40rpx;
}
