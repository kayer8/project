<app-navbar title="我的" left-arrow="{{false}}" />

<view class="page-body">
  <view wx:if="{{checking}}" class="profile-section profile-card profile-card--loading">
    <view class="profile-loading__avatar"></view>
    <view class="profile-loading__content">
      <view class="profile-loading__line profile-loading__line--title"></view>
      <view class="profile-loading__line"></view>
      <view class="profile-loading__line profile-loading__line--short"></view>
    </view>
  </view>

  <block wx:else>
    <view class="profile-section profile-header-card">
      <view class="profile-header__top">
        <view class="profile-user">
          <view wx:if="{{sessionUser && sessionUser.avatarUrl}}" class="profile-avatar">
            <image class="profile-avatar__image" src="{{sessionUser.avatarUrl}}" mode="aspectFill" />
          </view>
          <view wx:else class="profile-avatar profile-avatar--placeholder">{{displayInitial}}</view>

          <view class="profile-user__content">
            <view class="profile-user__name-row">
              <text class="profile-user__name">{{displayName}}</text>
              <text class="profile-user__role">{{identityLabel}}</text>
            </view>
            <view class="profile-user__house">{{houseSummary}}</view>
            <view class="profile-user__auth-row">
              <view class="profile-user__auth-pill">
                <t-icon name="secured" size="24rpx" class="profile-mini-icon" />
                <text>{{authStatusText}}</text>
              </view>
              <text class="profile-user__mobile">{{sessionUser && sessionUser.mobile ? sessionUser.mobile : '未绑定手机号'}}</text>
            </view>
          </view>
        </view>

        <view class="profile-status {{hasBoundHouse ? 'profile-status--success' : 'profile-status--pending'}}">
          {{hasBoundHouse ? authStatusText : '未绑定'}}
        </view>
      </view>
    </view>

    <view class="profile-section profile-card">
      <view class="profile-section__head">
        <view>
          <view class="profile-section__title">房屋信息</view>
          <view class="profile-section__desc">{{houseMetaText}}</view>
        </view>
      </view>

      <view class="house-card">
        <view class="house-card__content">
          <text class="house-card__label">当前房屋</text>
          <text class="house-card__value">{{activeHouseLabel}}</text>
        </view>
        <view class="house-card__actions">
          <view class="house-card__button house-card__button--ghost" bindtap="handleSwitchHouse">
            <t-icon name="swap" size="26rpx" class="profile-mini-icon" />
            <text>切换房屋</text>
          </view>
          <view class="house-card__button house-card__button--primary" bindtap="handleAddHouse">
            <t-icon name="add" size="26rpx" class="profile-mini-icon profile-mini-icon--light" />
            <text>添加房屋</text>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-section profile-card profile-card--menu">
      <view class="menu-list">
        <view
          wx:for="{{personalMenus}}"
          wx:key="key"
          class="menu-item"
          data-url="{{item.url}}"
          data-requires-house="{{item.requiresHouse}}"
          bindtap="handleMenuTap"
        >
          <view class="menu-item__left">
            <view class="menu-item__icon">
              <t-icon name="{{item.icon}}" size="36rpx" class="profile-menu-icon" />
            </view>
            <text class="menu-item__title">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{errorMessage}}" class="profile-section profile-warning">
      {{errorMessage}}
    </view>
  </block>

  <view class="safe-bottom-space"></view>
</view>
