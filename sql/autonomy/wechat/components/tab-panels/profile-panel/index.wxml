<app-navbar title="我的" left-arrow="{{false}}" />

<view class="page-body page-body--with-tabbar">
  <view class="summary-banner">
    <view class="icon-title-row">
      <t-icon name="user" size="48rpx" class="ui-icon ui-icon--primary" />
      <view class="summary-title">我的</view>
    </view>
    <view class="summary-desc">
      <block wx:if="{{checking}}">系统正在核验当前微信账号与社区账户的匹配状态，请稍候。</block>
      <block wx:elif="{{hasAccount}}">当前微信账号已匹配社区账户，可继续查看认证状态与账户资料。</block>
      <block wx:else>当前微信账号尚未匹配房屋信息，请先完成房屋绑定，再进入后续认证流程。</block>
    </view>
  </view>

  <view wx:if="{{checking}}" class="section card info-card">
    <view class="empty-block">正在核验账户状态，请稍候。</view>
  </view>

  <block wx:elif="{{hasAccount}}">
    <view class="section card info-card">
      <view class="section-head">
        <view>
          <view class="icon-title-row">
            <t-icon name="user" size="40rpx" class="ui-icon ui-icon--primary" />
            <view class="section-title">{{sessionUser.realName || sessionUser.nickname || '社区住户'}}</view>
          </view>
          <view class="section-subtitle">{{sessionUser.mobile || '未绑定手机号'}}</view>
        </view>
        <t-tag theme="success" variant="light">账户已匹配</t-tag>
      </view>

      <view class="info-row">
        <view class="info-label">账户状态</view>
        <view class="info-value">已完成微信账号匹配</view>
      </view>
      <view class="info-row">
        <view class="info-label">实名认证</view>
        <view class="info-value">{{verification.status === 'verified' ? '已通过' : verification.status === 'pending' ? '审核中' : '待提交'}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">手机号</view>
        <view class="info-value">{{sessionUser.mobile || '未绑定'}}</view>
      </view>
    </view>

    <view class="section card info-card profile-auth-card">
      <view class="section-head">
        <view>
          <view class="icon-title-row">
            <t-icon name="setting" size="40rpx" class="ui-icon ui-icon--primary" />
            <view class="section-title">账户服务</view>
          </view>
          <view class="section-subtitle">围绕房屋认证与资料说明提供统一入口</view>
        </view>
      </view>
      <t-cell-group>
        <t-cell
          title="实名认证"
          description="查看认证状态并提交或补充认证材料"
          note="{{verification.status === 'verified' ? '已通过' : verification.status === 'pending' ? '审核中' : '待提交'}}"
          arrow="{{true}}"
          url="/pages/profile/verification/index"
          jump-type="navigateTo"
        />
        <t-cell
          title="隐私政策"
          description="查看房屋绑定、认证与信息使用说明"
          note="协议说明"
          arrow="{{true}}"
          url="/pages/legal/privacy/index"
          jump-type="navigateTo"
        />
      </t-cell-group>
    </view>
  </block>

  <view wx:else class="section card info-card">
    <view class="section-head">
      <view>
        <view class="icon-title-row">
          <t-icon name="home" size="40rpx" class="ui-icon ui-icon--warning" />
          <view class="section-title">未绑定房屋</view>
        </view>
        <view class="section-subtitle">先完成房屋绑定，系统才能识别你的住户身份并进入认证流程。</view>
      </view>
    </view>

    <view class="profile-process">
      <view class="profile-process__item">
        <view class="profile-process__index">1</view>
        <view class="icon-inline-row">
          <t-icon name="user" size="32rpx" class="ui-icon" />
          <view class="profile-process__title">读取手机号</view>
        </view>
        <view class="profile-process__desc">通过微信手机号与物业留存资料进行比对。</view>
      </view>
      <view class="profile-process__item">
        <view class="profile-process__index">2</view>
        <view class="icon-inline-row">
          <t-icon name="home" size="32rpx" class="ui-icon" />
          <view class="profile-process__title">确认楼栋房屋</view>
        </view>
        <view class="profile-process__desc">未自动匹配时，补充楼栋与房屋信息提交审核。</view>
      </view>
      <view class="profile-process__item">
        <view class="profile-process__index">3</view>
        <view class="icon-inline-row">
          <t-icon name="check-circle" size="32rpx" class="ui-icon" />
          <view class="profile-process__title">进入认证</view>
        </view>
        <view class="profile-process__desc">绑定成功后，在“我的”中继续完成实名材料提交。</view>
      </view>
    </view>

    <view wx:if="{{errorMessage}}" class="section page-note page-note--warning">
      {{errorMessage}}
    </view>

    <button class="primary-button section" bindtap="goBindHouse">绑定房屋</button>
    <button wx:if="{{errorMessage}}" class="secondary-button section" bindtap="handleRetry">重新检查</button>
  </view>
</view>
