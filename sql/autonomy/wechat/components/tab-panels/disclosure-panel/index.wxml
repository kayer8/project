<app-navbar title="信息公开" left-arrow="{{false}}" />

<view class="page-body page-body--with-tabbar">
  <view class="summary-banner disclosure-hero">
    <view class="record-row disclosure-hero__head">
      <view>
        <view class="icon-title-row">
          <t-icon name="view-list" size="48rpx" class="ui-icon ui-icon--primary" />
          <view class="summary-title">社区信息公开</view>
        </view>
        <view class="disclosure-hero__publisher">发布主体：{{publishersLabel}}</view>
      </view>
      <t-tag theme="primary" variant="light">正式公开</t-tag>
    </view>
    <view class="disclosure-hero__metrics">
      <view class="disclosure-hero__item">
        <view class="disclosure-hero__label">公开栏目</view>
        <view class="disclosure-hero__value">{{sections.length}} 类</view>
      </view>
      <view class="disclosure-hero__item">
        <view class="disclosure-hero__label">最新更新</view>
        <view class="disclosure-hero__value">{{latestAnnouncements.length}} 条</view>
      </view>
      <view class="disclosure-hero__item">
        <view class="disclosure-hero__label">最近更新时间</view>
        <view class="disclosure-hero__value">{{latestUpdate}}</view>
      </view>
    </view>
  </view>

  <view class="section disclosure-hero__tip">
    <t-icon name="info-circle" size="32rpx" class="ui-icon" />
    <view>公开信息按公告、财务、管理和缴费分类归档，优先查看有状态更新的栏目。</view>
  </view>

  <view class="section card info-card disclosure-section-block">
    <view class="section-head disclosure-section-block__head">
      <view>
        <view class="icon-title-row">
          <t-icon name="view-list" size="40rpx" class="ui-icon ui-icon--primary" />
          <view class="section-title">公开栏目</view>
        </view>
        <view class="section-subtitle">从栏目入口快速进入对应的正式公开页面</view>
      </view>
    </view>
    <view wx:for="{{sections}}" wx:key="title" class="record-card disclosure-section" data-url="{{item.url}}" bindtap="openSection">
      <view class="record-row disclosure-section__row">
        <view class="disclosure-section__main">
          <view class="disclosure-section__icon">
            <t-icon name="{{item.icon}}" size="40rpx" class="ui-icon ui-icon--primary" />
          </view>
          <view class="disclosure-section__content">
            <view class="record-title">{{item.title}}</view>
            <view class="record-note">{{item.desc}}</view>
          </view>
        </view>
        <t-tag theme="{{item.tagTheme}}" variant="light">{{item.note}}</t-tag>
      </view>
    </view>
  </view>

  <view class="section card info-card disclosure-latest-block">
    <view class="section-head">
      <view>
        <view class="icon-title-row">
          <t-icon name="notification" size="40rpx" class="ui-icon ui-icon--primary" />
          <view class="section-title">最新公示</view>
        </view>
        <view class="section-subtitle">近期已发布的重点公开信息</view>
      </view>
    </view>
    <view wx:for="{{latestAnnouncements}}" wx:key="id" class="record-card disclosure-record" data-id="{{item.id}}" bindtap="openDetail">
      <view class="record-row">
        <view>
          <view class="icon-inline-row">
            <t-icon name="notification" size="32rpx" class="ui-icon" />
            <view class="record-title">{{item.title}}</view>
          </view>
          <view class="record-note">{{item.category}} · {{item.date}} · {{item.publisher}}</view>
        </view>
        <view class="badge-row">
          <t-tag theme="{{item.important ? 'warning' : 'primary'}}" variant="light">{{item.important ? '重点公开' : '常规公开'}}</t-tag>
        </view>
      </view>
      <view class="record-note disclosure-record__serial">公示编号：{{item.sourceNo}}</view>
    </view>
  </view>
</view>
