<app-navbar title="首页" left-arrow="{{false}}" />

<t-pull-down-refresh
  class="panel-refresh"
  enable-passive="{{true}}"
  loadingProps="{{PULL_DOWN_LOADING_PROPS}}"
  value="{{isRefreshing}}"
  bind:refresh="onPanelRefresh"
>
<view class="page-body ">
  <view class="card info-card home-profile-card">
    <view class="home-profile-card__head">
      <view class="home-profile-card__identity">
        <view class="home-profile-card__house-side">
          <view class="home-profile-card__house-icon">
            <t-icon name="home" size="40rpx" />
          </view>
          <view class="home-profile-card__community">{{homeProfileCard.communityName}}</view>
        </view>

        <view class="home-profile-card__meta">
          <view class="home-profile-card__name-row">
            <view class="home-profile-card__name">{{homeProfileCard.houseName}}</view>
            <t-tag wx:if="{{homeProfileCard.houseRole}}" theme="primary" variant="light">
              {{homeProfileCard.houseRole}}
            </t-tag>
            <t-tag
              wx:if="{{homeProfileCard.statusTag}}"
              theme="{{homeProfileCard.statusTag === '已绑定' ? 'success' : 'warning'}}"
              variant="light"
            >
              {{homeProfileCard.statusTag}}
            </t-tag>
          </view>
          <view class="home-profile-card__subtitle">{{homeProfileCard.subtitle}}</view>
        </view>
      </view>

      <view class="home-profile-card__link" bindtap="openHouseSwitcher">
        <t-icon name="swap" size="32rpx" />
      </view>
    </view>

    <view class="home-profile-card__stats">
      <view wx:for="{{homeProfileCard.stats}}" wx:key="label" class="home-profile-card__stat">
        <view class="home-profile-card__stat-label">{{item.label}}</view>
        <view class="home-profile-card__stat-value">{{item.value}}</view>
      </view>
    </view>

    <view class="home-profile-card__actions">
      <view
        wx:for="{{homeProfileCard.actions}}"
        wx:key="title"
        class="home-profile-card__action home-profile-card__action--{{item.theme}}"
        data-url="{{item.url}}"
        bindtap="openCardAction"
      >
        {{item.title}}
      </view>
    </view>
  </view>

  <view class="section card info-card disclosure-section-block">
    <view class="section-head disclosure-section-block__head">
      <view class="icon-title-row">
        <view class="section-title">常用工具</view>
      </view>
    </view>

    <view class="disclosure-section-grid">
      <view
        wx:for="{{sections}}"
        wx:key="key"
        class="disclosure-section-grid__item"
        data-url="{{item.url}}"
        data-requires-house="{{item.requiresHouse}}"
        bindtap="openSection"
      >
        <view
          class="disclosure-section-grid__icon"
          style="background: {{item.iconBackground}}; color: {{item.iconColor}};"
        >
          <t-icon name="{{item.icon}}" size="40rpx" />
        </view>
        <view class="disclosure-section-grid__title">{{item.title}}</view>
      </view>
    </view>
  </view>

  <view class="section card info-card vote-guide-card">
    <view style="position:absolute;width: 100%;height: 100%;left: 0; z-index: -1;">
      <image style="width:100%;height:100% ;border-radius: 20rpx;" src="./banner_bg.png" mode="aspectFill" />
    </view>
    <view class="vote-guide-card__content">
      <view class="vote-guide-card__eyebrow">投票提醒</view>
      <view class="vote-guide-card__title">{{voteGuideCard.title}}</view>
    </view>
    <button class="vote-guide-card__button" bindtap="openVoteGuide">
      {{voteGuideCard.buttonText}}
    </button>
  </view>

  <view class="section  card info-card disclosure-latest-block">
    <view class="section-head">
      <view class="icon-title-row">
        <view class="section-title">最新公示</view>
      </view>
    </view>

    <view wx:if="{{loadingLatest}}" class="disclosure-latest-block__loading">
      <t-loading theme="circular" size="56rpx" />
    </view>

    <view wx:elif="{{!latestAnnouncements.length}}" class="empty-block">
      暂无公开内容
    </view>

    <block wx:else>
      <view
        wx:for="{{latestAnnouncements}}"
        wx:key="id"
        class="record-card disclosure-record"
        data-id="{{item.id}}"
        bindtap="openDetail"
      >
        <view class="record-row">
          <view>
            <view class="icon-inline-row">
              <view class="record-title">{{item.title}}</view>
            </view>
            <view class="record-note">{{item.category}} · {{item.displayDate}} · {{item.publisher}}</view>
          </view>
          <t-tag theme="primary" variant="light">{{item.category}}</t-tag>
        </view>
      </view>
    </block>
  </view>
</view>
</t-pull-down-refresh>

<t-popup
  visible="{{houseSwitcherVisible}}"
  placement="bottom"
  bind:visible-change="handleHouseSwitcherVisibleChange"
>
  <view class="house-switcher-popup">
    <view class="house-switcher-popup__header">
      <view class="house-switcher-popup__title">切换房屋</view>
      <view class="house-switcher-popup__close" bindtap="closeHouseSwitcher">
        <t-icon name="close" size="30rpx" />
      </view>
    </view>

    <scroll-view class="house-switcher-popup__scroll" scroll-y>
      <view wx:if="{{boundHouses.length}}">
        <view
          wx:for="{{boundHouses}}"
          wx:key="id"
          class="house-switcher-item {{selectedHouseId === item.id ? 'house-switcher-item--active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleSelectHouse"
        >
          <view class="house-switcher-item__content">
            <view class="house-switcher-item__title-row">
              <view class="house-switcher-item__title">{{item.houseName}}</view>
              <t-tag wx:if="{{item.roleLabel}}" theme="primary" variant="light">{{item.roleLabel}}</t-tag>
              <t-tag
                wx:if="{{item.statusTag}}"
                theme="{{item.statusTag === '已绑定' ? 'success' : 'warning'}}"
                variant="light"
              >
                {{item.statusTag}}
              </t-tag>
            </view>
            <view class="house-switcher-item__subtitle">{{item.subtitle}}</view>
          </view>

          <view wx:if="{{selectedHouseId === item.id}}" class="house-switcher-item__check">
            <t-icon name="check-circle-filled" size="34rpx" />
          </view>
        </view>
      </view>

      <view wx:else class="house-switcher-popup__empty">
        当前还没有已绑定房屋
      </view>
    </scroll-view>

    <view class="house-switcher-popup__footer">
      <t-button theme="primary" size="large" shape="round" block bindtap="handleBindNewHouse">
        绑定新房屋
      </t-button>
    </view>
  </view>
</t-popup>
