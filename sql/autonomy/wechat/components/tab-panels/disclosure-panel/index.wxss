.panel-refresh {
  display: block;
  height: 100%;
}

.page-body {
  box-sizing: border-box;
  min-height: 100%;
  padding: 24rpx 24rpx 48rpx;
}

.disclosure-hero__head {
  align-items: center;
}

.disclosure-hero__publisher {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #5f6b7a;
}

.disclosure-hero__metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.disclosure-hero__item {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1px solid #e2ebf8;
  background: #f6f9fe;
}

.disclosure-hero__label {
  font-size: 22rpx;
  color: #86909c;
}

.disclosure-hero__value {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f5fbf;
}

.disclosure-hero__tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #5f6b7a;
  font-size: 22rpx;
  line-height: 1.6;
}

.home-profile-card {
  padding: 26rpx 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9fd 100%);
}

.home-profile-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.home-profile-card__identity {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-width: 0;
  flex: 1;
}

.home-profile-card__house-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.home-profile-card__house-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #eaf1ff 0%, #dfe9ff 100%);
  color: #2f6bff;
  flex-shrink: 0;
}

.home-profile-card__community {
  max-width: 132rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #7a8599;
  text-align: center;
}

.home-profile-card__meta {
  min-width: 0;
  flex: 1;
}

.home-profile-card__name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.home-profile-card__name {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2329;
}

.home-profile-card__subtitle {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7a8599;
}

.home-profile-card__link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #eef3ff;
  color: #3a66e9;
  flex-shrink: 0;
}

.house-switcher-popup {
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #ffffff 0%, #f7f9fd 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.house-switcher-popup__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.house-switcher-popup__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.house-switcher-popup__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #eef3ff;
  color: #3a66e9;
}

.house-switcher-popup__scroll {
  max-height: 58vh;
  margin-top: 22rpx;
}

.house-switcher-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1px solid #e6ebf2;
  box-shadow: 0 10rpx 30rpx rgba(31, 95, 191, 0.04);
}

.house-switcher-item + .house-switcher-item {
  margin-top: 16rpx;
}

.house-switcher-item--active {
  border-color: #b9ccff;
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
}

.house-switcher-item__content {
  min-width: 0;
  flex: 1;
}

.house-switcher-item__title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.house-switcher-item__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1f2329;
}

.house-switcher-item__subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a8599;
}

.house-switcher-item__check {
  color: #2f6bff;
  flex-shrink: 0;
}

.house-switcher-popup__empty {
  padding: 56rpx 0 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #7a8599;
}

.house-switcher-popup__footer {
  margin-top: 24rpx;
}

.home-profile-card__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 24rpx;
  border: 1px solid #e6ebf2;
  border-radius: 18rpx;
  background: #fbfcfe;
  overflow: hidden;
}

.home-profile-card__stat {
  padding: 18rpx 12rpx;
  text-align: center;
}

.home-profile-card__stat + .home-profile-card__stat {
  border-left: 1px solid #e6ebf2;
}

.home-profile-card__stat-label {
  font-size: 22rpx;
  color: #8a94a6;
}

.home-profile-card__stat-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #2f6bff;
}

.home-profile-card__actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.home-profile-card__action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.home-profile-card__action--primary {
  background: linear-gradient(135deg, #2f6bff 0%, #4b7dff 100%);
  color: #ffffff;
}

.home-profile-card__action--secondary {
  border: 1px solid #dde5f0;
  background: #ffffff;
  color: #334155;
}

.disclosure-section-block,
.disclosure-latest-block {
  padding: 26rpx 24rpx;
}

.vote-guide-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  position: relative;
  background-color: transparent;
  border: none;
  /* background: linear-gradient(135deg, #2f6bff 0%, #4b7dff 100%); */
}

.vote-guide-card__content {
  min-width: 0;
  flex: 1;
}

.vote-guide-card__eyebrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.84);
}

.vote-guide-card__title {
  margin-top: 8rpx;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #ffffff;
}

.vote-guide-card__button {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #2f6bff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  max-width: 200rpx;
}

.disclosure-section-block__head {
  margin-bottom: 20rpx;
}

.disclosure-record + .disclosure-record {
  margin-top: 18rpx;
}

.disclosure-latest-block__loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 180rpx;
}

.disclosure-section-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 20rpx 12rpx;
}

.disclosure-section-grid__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
  padding: 8rpx 4rpx;
}

.disclosure-section-grid__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
}

.disclosure-section-grid__title {
  font-size: 24rpx;
  line-height: 1.4;
  color: #1f2329;
  text-align: center;
}

.disclosure-record__serial {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #5f6b7a;
}

@media (max-width: 560px) {
  .disclosure-section-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18rpx 8rpx;
  }

  .disclosure-section-grid__icon {
    width: 76rpx;
    height: 76rpx;
    border-radius: 22rpx;
  }

  .disclosure-section-grid__title {
    font-size: 22rpx;
  }

  .home-profile-card__name {
    font-size: 32rpx;
  }

  .home-profile-card__action {
    height: 80rpx;
    font-size: 26rpx;
  }
}
