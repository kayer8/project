<app-navbar title="社区投票" left-arrow="{{false}}" />

<view class="page-body page-body--with-tabbar">
  <view class="summary-banner voting-hero">
    <view class="icon-title-row">
      <t-icon name="check-circle" size="48rpx" class="ui-icon ui-icon--primary" />
      <view class="summary-title">社区议题表决</view>
    </view>
    <view class="summary-desc">正式议题与意见征集统一纳入线上投票，明确发起方、截止时间、参与情况与当前状态，确保社区事项有序协商。</view>
    <view class="voting-hero__meta">
      <view class="voting-hero__item">
        <view class="voting-hero__label">当前议题</view>
        <view class="voting-hero__value">{{votes.length}} 项</view>
      </view>
      <view class="voting-hero__item">
        <view class="voting-hero__label">参与规则</view>
        <view class="voting-hero__value">一户一票 / 一人一票</view>
      </view>
    </view>
  </view>

  <view class="section page-note">正式决策议题建议采用一户一票，意见征集建议采用一人一票。所有投票记录将在截止后归档留痕。</view>

  <view class="section action-row">
    <button class="primary-button" bindtap="openCreateVote">发起正式投票</button>
    <button class="secondary-button" bindtap="openCreateVote">发起意见征集</button>
  </view>

  <view class="section">
    <view wx:for="{{votes}}" wx:key="id" class="record-card vote-record" data-id="{{item.id}}" bindtap="openVoteDetail">
      <view class="record-row">
        <view>
          <view class="icon-inline-row">
            <t-icon name="check-circle" size="32rpx" class="ui-icon" />
            <view class="record-title">{{item.title}}</view>
          </view>
          <view class="record-note">发起方：{{item.sponsor}} · 截止 {{item.endTime}}</view>
        </view>
        <view class="badge-row">
          <t-tag theme="{{item.status === '进行中' ? 'primary' : 'default'}}" variant="light">{{item.status}}</t-tag>
          <t-tag theme="warning" variant="light">{{item.type}}</t-tag>
          <t-tag theme="{{item.voted ? 'success' : 'warning'}}" variant="light">{{item.voted ? '已投票' : '未投票'}}</t-tag>
        </view>
      </view>
      <view class="vote-record__meta">
        <view class="vote-record__meta-item">参与范围：{{item.scope}}</view>
        <view class="vote-record__meta-item">参与情况：{{item.participants}} / {{item.total}}</view>
      </view>
      <view class="list-desc">{{item.description}}</view>
    </view>
  </view>
</view>
