<view class="page-shell">
  <app-navbar title="登录" left-arrow="{{true}}" />

  <view class="page-body">
    <view class="hero-panel">
      <view class="icon-title-row">
        <t-icon name="user" size="48rpx" class="ui-icon ui-icon--primary" />
        <view class="hero-title">物业自治</view>
      </view>
      <view class="hero-subtitle">
        正在检查你的微信账户是否已注册，并准备进入对应流程。
      </view>
    </view>

    <view class="section card info-card">
      <view wx:if="{{checking}}" class="empty-block">正在校验登录状态，请稍候…</view>
      <view wx:else>
        <view class="status-hint">
          <t-icon name="close-circle" size="32rpx" class="ui-icon ui-icon--danger" />
          <view class="list-desc">{{errorMessage || '登录失败，请重试'}}</view>
        </view>
        <button class="primary-button login-retry" bindtap="handleRetry">重新检查</button>
      </view>
    </view>
  </view>
</view>
