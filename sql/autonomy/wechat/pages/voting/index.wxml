<view class="page-shell">
  <app-navbar title="投票决策" left-arrow="{{false}}" />

  <view class="page-body page-body--with-tabbar">
    <view class="summary-banner">
      <view class="summary-title">社区决策透明可追溯</view>
      <view class="summary-desc">把正式投票和意见征集分开处理，避免复杂流程挤在一个弹层里。</view>
    </view>

    <view class="section action-row">
      <button class="secondary-button" bindtap="openCreateVote">发起投票</button>
      <button class="primary-button" bindtap="openCreateVote">创建征集</button>
    </view>

    <view class="section">
      <view wx:for="{{votes}}" wx:key="id" class="record-card" data-id="{{item.id}}" bindtap="openVoteDetail">
        <view class="record-row">
          <view>
            <view class="record-title">{{item.title}}</view>
            <view class="record-note">截止 {{item.endTime}} · {{item.participants}} / {{item.total}} 已参与</view>
          </view>
          <view class="badge-row">
            <t-tag theme="{{item.status === '进行中' ? 'primary' : 'default'}}" variant="light">{{item.status}}</t-tag>
            <t-tag theme="warning" variant="light">{{item.type}}</t-tag>
          </view>
        </view>
        <view class="list-desc">{{item.description}}</view>
      </view>
    </view>

    <view class="section page-note">
      正式决策可按“一户一票”发起，意见征集则按“一人一票”处理。后面接真实数据时，可以直接映射到现有住户和房屋关系。
    </view>
  </view>

  <app-tabbar value="voting" />
</view>
