.page-body {
  padding: 24rpx 24rpx 48rpx;
}

.detail-title {
  margin-top: 14rpx;
}

.vote-meta-list {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}

.vote-meta-list__item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 12rpx;
  border-top: 1px solid #edf1f5;
}

.vote-meta-list__label {
  font-size: 23rpx;
  color: #86909c;
}

.vote-meta-list__value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #1f2329;
}

.vote-option {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1px solid #d7dee8;
  font-size: 28rpx;
  color: #1f2329;
}

.vote-option--active {
  border-color: #1f5fbf;
  background: #f4f8ff;
}

.result-block + .result-block {
  margin-top: 20rpx;
}

.result-bar {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  overflow: hidden;
}

.result-bar__inner {
  height: 100%;
  border-radius: 999rpx;
  background: #1f5fbf;
}
