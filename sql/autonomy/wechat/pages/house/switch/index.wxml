<view class="page-shell">
  <view class="card">
    <view class="section-title">切换当前操作房屋</view>
    <view class="list-desc">首页、投票详情、账单和消息提醒都会按当前房屋上下文展示。</view>
  </view>

  <view wx:for="{{houses}}" wx:key="id" class="list-card">
    <view class="list-title">{{item.name}}</view>
    <view class="tag-row">
      <view class="pill">{{item.identityLabel}}</view>
      <view class="pill">{{item.statusLabel}}</view>
      <view wx:if="{{item.id === currentHouseId}}" class="pill pill-warning">当前房屋</view>
    </view>
    <view class="list-desc">认证 {{item.authStatusLabel}} · 成员 {{item.memberCount}} 人</view>
    <view class="list-meta">正式表决资格：{{item.hasVoteRight ? '可参与' : '不可参与'}}</view>
    <view class="button-row">
      <button class="secondary-button" data-id="{{item.id}}" bindtap="handleOpenDetail">房屋详情</button>
      <button
        wx:if="{{item.id !== currentHouseId}}"
        class="primary-button"
        data-id="{{item.id}}"
        data-role="{{item.identityLabel}}"
        bindtap="handleSelect"
      >
        切换到此房屋
      </button>
    </view>
  </view>
</view>
