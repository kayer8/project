.financial-header {
  margin-bottom: 24rpx;
}

.financial-card + .financial-card {
  margin-top: 16rpx;
}

.financial-filter {
  margin-bottom: 16rpx;
}

.financial-filter__btn {
  min-width: 120rpx;
}

.financial-filter__btn--active {
  background: #1f5fbf;
  border-color: #1f5fbf;
  color: #ffffff;
}

.text-income {
  color: #1d6f42;
}

.text-expense {
  color: #c2410c;
}

.result-bar {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  overflow: hidden;
}

.result-bar__inner {
  height: 100%;
  border-radius: 999rpx;
  background: #1f5fbf;
}
