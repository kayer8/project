<view class="page-shell">
  <app-navbar title="公告详情" />

  <view class="page-body">
    <view wx:if="{{item}}" class="section notice-doc">
      <view class="notice-doc__tags">
        <t-tag theme="default" variant="light">{{item.category}}</t-tag>
        <t-tag wx:if="{{item.important}}" theme="danger" variant="light">重点</t-tag>
      </view>

      <view class="notice-doc__title">{{item.title}}</view>

      <view class="notice-doc__meta-grid">
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">发布单位</view>
          <view class="notice-doc__meta-value">{{item.publisher}}</view>
        </view>
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">发布时间</view>
          <view class="notice-doc__meta-value">{{item.date}}</view>
        </view>
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">公示编号</view>
          <view class="notice-doc__meta-value">{{item.sourceNo}}</view>
        </view>
        <view class="notice-doc__meta-item notice-doc__meta-item--minor">
          <view class="notice-doc__meta-label">阅读</view>
          <view class="notice-doc__meta-value">{{item.views}} 次</view>
        </view>
      </view>

      <view class="notice-doc__divider" />

      <view class="notice-doc__body">
        <view class="notice-doc__body-title">公告正文</view>
        <view class="detail-content">{{item.content}}</view>
      </view>
    </view>

    <view wx:if="{{!item}}" class="section">
      <t-empty description="未找到对应公告" />
    </view>
  </view>
</view>
