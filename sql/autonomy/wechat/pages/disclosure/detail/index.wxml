  <app-navbar title="公告" />

  <view class="page-body">
    <view wx:if="{{loading}}" class="section">
      <view class="record-note">正在加载公开详情...</view>
    </view>

    <view wx:if="{{item}}" class="section notice-doc">
      <view class="notice-doc__title">{{item.title}}</view>

      <view class="notice-doc__body">
        <block wx:if="{{item.contentParagraphs.length}}">
          <view
            wx:for="{{item.contentParagraphs}}"
            wx:for-item="paragraph"
            wx:key="index"
            class="notice-doc__paragraph"
          >{{paragraph}}</view>
        </block>
        <view wx:else class="notice-doc__paragraph">{{item.contentText}}</view>
      </view>

      <view class="notice-doc__divider" />

      <view class="notice-doc__meta-grid">
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">发布单位</view>
          <view class="notice-doc__meta-value">{{item.publisher}}</view>
        </view>
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">发布时间</view>
          <view class="notice-doc__meta-value">{{item.displayDate}}</view>
        </view>
        <view class="notice-doc__meta-item">
          <view class="notice-doc__meta-label">公开分类</view>
          <view class="notice-doc__meta-value">{{item.category}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && !item}}" class="section">
      <t-empty description="{{errorMessage || '未找到对应公开内容'}}" />
    </view>
  </view>
