<app-navbar title="{{disclosureTitle || '收费公示'}}" />

<view class="page-body">
  <app-list
    list="{{periodCards}}"
    loading="{{loading}}"
    showLoading="{{true}}"
    isLoadMore="{{isLoadMore}}"
    finished="{{finished}}"
    enableLoadMore="{{false}}"
    content-class="payment-list-content"
    emptyDescription="{{emptyDescription}}"
    bind:refresh="onListRefresh"
  >
    <view class="payment-summary">
      <view class="payment-summary__card">
        <view class="payment-summary__label">账期总数</view>
        <view class="payment-summary__value">{{summary.periodCountText}}</view>
      </view>
      <view class="payment-summary__card">
        <view class="payment-summary__label">总应收</view>
        <view class="payment-summary__value">{{summary.receivableText}}</view>
      </view>
      <view class="payment-summary__card">
        <view class="payment-summary__label">总实收</view>
        <view class="payment-summary__value">{{summary.paidText}}</view>
      </view>
      <view class="payment-summary__card payment-summary__card--accent">
        <view class="payment-summary__label">综合缴费率</view>
        <view class="payment-summary__value">{{summary.paymentRateText}}</view>
      </view>
    </view>

    <view class="payment-filters">
      <view class="payment-filters__row">
        <view class="payment-filter" bindtap="openPeriodPicker">
          <view class="payment-filter__field">
            <view class="payment-filter__label">账期</view>
            <view class="payment-filter__value">{{currentPeriodLabel}}</view>
            <view class="payment-filter__arrow"></view>
          </view>
        </view>

        <view class="payment-filter" bindtap="openBuildingPicker">
          <view class="payment-filter__field">
            <view class="payment-filter__label">楼栋</view>
            <view class="payment-filter__value">{{currentBuildingLabel}}</view>
            <view class="payment-filter__arrow"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="payment-periods">
      <view
        wx:for="{{periodCards}}"
        wx:key="periodKey"
        wx:for-item="period"
        class="payment-card payment-card--{{period.statusTone}}"
        data-key="{{period.periodKey}}"
        bindtap="openDetail"
      >
        <view class="payment-card__top">
          <view class="payment-card__heading">
            <view class="payment-card__title">{{period.rangeText}}</view>
            <view class="payment-card__meta">更新于 {{period.updatedAtText}}</view>
          </view>
          <view class="payment-card__status payment-card__status--{{period.statusTone}}">
            {{period.statusLabel}}
          </view>
        </view>

        <view class="payment-card__metrics">
          <view class="payment-card__metric">
            <view class="payment-card__metric-label">总应收金额</view>
            <view class="payment-card__metric-value">{{period.receivableText}}</view>
          </view>
          <view class="payment-card__metric">
            <view class="payment-card__metric-label">总实收金额</view>
            <view class="payment-card__metric-value">{{period.paidText}}</view>
          </view>
          <view class="payment-card__metric payment-card__metric--rate">
            <view class="payment-card__metric-label">缴费率</view>
            <view class="payment-card__metric-value payment-card__metric-value--{{period.statusTone}}">
              {{period.paymentRateText}}
            </view>
          </view>
        </view>

        <view class="payment-card__bottom">
          <view class="payment-card__extra">
            <text>{{period.unpaidHouseholdsText}}</text>
          </view>
          <view class="payment-card__action">
            <view class="payment-card__detail">
              <text>查看详情</text>
              <view class="payment-card__arrow"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </app-list>

  <t-picker
    visible="{{periodPickerVisible}}"
    title="选择账期"
    value="{{periodPickerValue}}"
    bind:confirm="handlePeriodConfirm"
    bind:cancel="closePeriodPicker"
    bind:visible-change="handlePeriodPickerVisibleChange"
  >
    <t-picker-item options="{{periodPickerOptions}}" />
  </t-picker>

  <t-picker
    visible="{{buildingPickerVisible}}"
    title="选择楼栋"
    value="{{buildingPickerValue}}"
    bind:confirm="handleBuildingConfirm"
    bind:cancel="closeBuildingPicker"
    bind:visible-change="handleBuildingPickerVisibleChange"
  >
    <t-picker-item options="{{buildingPickerOptions}}" />
  </t-picker>
</view>
