<app-navbar title="收费公开" />

<view class="page-body">
  <view class="section card info-card">
    <view class="icon-title-row">
      <t-icon name="time" size="40rpx" class="ui-icon ui-icon--primary" />
      <view class="section-title">收费公开内容</view>
    </view>
    <view class="list-desc">展示收费标准、账期说明与收费公示等公开内容。</view>
  </view>

  <view class="section section--fill">
    <app-list
      list="{{items}}"
      loading="{{loading}}"
      showLoading="{{true}}"
      isLoadMore="{{isLoadMore}}"
      finished="{{finished}}"
      emptyDescription="{{errorMessage || '暂无收费公开内容'}}"
      bind:refresh="onListRefresh"
      bind:loadMore="onListLoadMore"
    >
      <view wx:for="{{items}}" wx:key="id" class="record-card payment-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="record-row">
          <view>
            <view class="icon-inline-row">
              <t-icon name="time" size="32rpx" class="ui-icon" />
              <view class="record-title">{{item.title}}</view>
            </view>
            <view class="record-note">{{item.displayDate}} · {{item.publisher}}</view>
          </view>
          <t-tag theme="success" variant="light">{{item.category}}</t-tag>
        </view>
        <view class="list-desc">{{item.preview}}</view>
      </view>
    </app-list>
  </view>
</view>
