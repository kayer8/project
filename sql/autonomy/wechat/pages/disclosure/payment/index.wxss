.page-body {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(79, 125, 255, 0.1), transparent 28%),
    linear-gradient(180deg, #f7f9fc 0%, #f2f5f9 100%);
  padding-bottom: 48rpx;
}

.payment-list-content {
  padding: 0 28rpx 36rpx;
}

.payment-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.payment-summary__card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(31, 51, 81, 0.05);
}

.payment-summary__card--accent {
  background:
    linear-gradient(135deg, rgba(59, 130, 246, 0.14), rgba(255, 255, 255, 0.92)),
    #ffffff;
}

.payment-summary__label {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #7c8a9d;
}

.payment-summary__value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
  color: #18283d;
}

.payment-filters {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 36rpx rgba(30, 48, 80, 0.05);
}

.payment-filters__row {
  display: flex;
  gap: 16rpx;
}

.payment-filter {
  flex: 1;
  min-width: 0;
}

.payment-filter__field {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  min-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #f5f7fb;
}

.payment-filter__label {
  grid-column: 1;
  font-size: 22rpx;
  line-height: 30rpx;
  color: #8a97aa;
}

.payment-filter__value {
  grid-column: 1;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 38rpx;
  color: #1c2d42;
}

.payment-filter__arrow {
  width: 14rpx;
  height: 14rpx;
  margin-left: 14rpx;
  border-right: 2rpx solid #7f8ea2;
  border-bottom: 2rpx solid #7f8ea2;
  transform: rotate(45deg);
}

.payment-periods {
  margin-top: 26rpx;
}

.payment-card {
  position: relative;
  padding: 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(32, 52, 84, 0.06);
}

.payment-card + .payment-card {
  margin-top: 22rpx;
}

.payment-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 10rpx;
  border-radius: 30rpx 30rpx 0 0;
}

.payment-card--high::before {
  background: linear-gradient(90deg, #2eb67d, #4ecf93);
}

.payment-card--medium::before {
  background: linear-gradient(90deg, #f59e0b, #f8b84d);
}

.payment-card--low::before {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

.payment-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.payment-card__heading {
  min-width: 0;
  flex: 1;
}

.payment-card__title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
  color: #162536;
}

.payment-card__meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #7f8c9e;
}

.payment-card__status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 30rpx;
}

.payment-card__status--high {
  color: #166b49;
  background: #e8f7ef;
}

.payment-card__status--medium {
  color: #9d5b00;
  background: #fff3dc;
}

.payment-card__status--low {
  color: #a23a3a;
  background: #fdeaea;
}

.payment-card__metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 26rpx;
}

.payment-card__metric {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.payment-card__metric--rate {
  background: linear-gradient(180deg, #eef5ff 0%, #f8fbff 100%);
}

.payment-card__metric-label {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #8492a6;
}

.payment-card__metric-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
  color: #162536;
}

.payment-card__metric-value--high {
  color: #1d8a5b;
}

.payment-card__metric-value--medium {
  color: #db8b0a;
}

.payment-card__metric-value--low {
  color: #dc4f4f;
}

.payment-card__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.payment-card__extra {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #607086;
}

.payment-card__action {
  display: flex;
  align-items: center;
}

.payment-card__detail {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 34rpx;
  color: #2563eb;
}

.payment-card__arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #2563eb;
  border-right: 2rpx solid #2563eb;
  transform: rotate(45deg);
}
