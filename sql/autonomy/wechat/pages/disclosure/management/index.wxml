<app-navbar title="管理公开" />

<view class="page-body">
  <view class="section card info-card">
    <view class="record-row">
      <view>
        <view class="icon-title-row">
          <t-icon name="view-list" size="40rpx" class="ui-icon ui-icon--primary" />
          <view class="section-title">管理动态</view>
        </view>
        <view class="list-desc">展示已发布的管理公开内容、整改说明和维保公示。</view>
      </view>
      <button class="secondary-button" bindtap="openMaintenance">维保记录</button>
    </view>
  </view>

  <view class="section section--fill">
    <app-list
      list="{{updates}}"
      loading="{{loading}}"
      showLoading="{{true}}"
      isLoadMore="{{isLoadMore}}"
      finished="{{finished}}"
      content-class="list-content"
      emptyDescription="{{errorMessage || '暂无管理公开内容'}}"
      bind:refresh="onListRefresh"
      bind:loadMore="onListLoadMore"
    >
      <view wx:for="{{updates}}" wx:key="id" class="record-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="record-row">
          <view>
            <view class="icon-inline-row">
              <t-icon name="setting" size="32rpx" class="ui-icon" />
              <view class="record-title">{{item.title}}</view>
            </view>
            <view class="record-note">{{item.displayDate}} · {{item.publisher}}</view>
          </view>
          <t-tag theme="primary" variant="light">{{item.category}}</t-tag>
        </view>
        <view class="list-desc">{{item.preview}}</view>
      </view>
    </app-list>
  </view>
</view>
