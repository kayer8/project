<view class="page-shell">
  <app-navbar title="维保记录" />

  <view class="page-body">
    <view class="summary-banner">
      <view class="icon-title-row">
        <t-icon name="setting" size="48rpx" class="ui-icon ui-icon--primary" />
        <view class="summary-title">维保记录</view>
      </view>
      <view class="summary-desc">按时间归档展示社区设备设施维保、检测与整改进展，便于居民持续监督。</view>
    </view>

    <view class="section page-note">维保结果与供应商信息同步留档，已完成事项可在记录中查看执行结果。</view>

    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view class="record-row">
        <view>
          <view class="icon-inline-row">
            <t-icon name="{{item.status === '已完成' ? 'check-circle' : 'time'}}" size="32rpx" class="ui-icon {{item.status === '已完成' ? 'ui-icon--success' : 'ui-icon--warning'}}" />
            <view class="record-title">{{item.title}}</view>
          </view>
          <view class="record-note">{{item.date}} · {{item.vendor}}</view>
        </view>
        <t-tag theme="{{item.status === '已完成' ? 'success' : 'primary'}}" variant="light">{{item.status}}</t-tag>
      </view>
      <view class="list-desc">检测结果：{{item.result}}</view>
    </view>
  </view>
</view>
