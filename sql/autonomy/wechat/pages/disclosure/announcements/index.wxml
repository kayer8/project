<view class="page-shell">
  <app-navbar title="公告通知" />

  <view class="page-body">
    <view class="section card info-card notice-search">
      <t-input
        t-class="toolbar-input"
        t-class-input="toolbar-input__element"
        borderless="{{true}}"
        clearable="{{true}}"
        placeholder="搜索公告 / 分类"
        value="{{keyword}}"
        bind:change="handleKeywordInput"
      />
    </view>

    <view class="section">
      <view wx:for="{{filteredAnnouncements}}" wx:key="id" class="record-card notice-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="record-row">
          <view class="notice-card__main">
            <view class="icon-inline-row">
              <view class="record-title">{{item.title}}</view>
            </view>
            <view class="record-note">{{item.category}} · {{item.date}} · {{item.views}} 次阅读</view>
          </view>
          <view class="notice-card__status">
            <view wx:if="{{item.important}}" class="notice-card__status-tag">
              <t-tag theme="danger" variant="light">重点</t-tag>
            </view>
          </view>
        </view>
        <view class="notice-card__serial">发布单位：{{item.publisher}} · 公示编号：{{item.sourceNo}}</view>
        <view class="notice-card__footer">
          <view class="list-desc notice-card__body">{{item.content}}</view>
          <view wx:if="{{!item.isRead}}" class="notice-card__dot" />
        </view>
      </view>
    </view>

    <view wx:if="{{!filteredAnnouncements.length}}" class="section">
      <t-empty description="没有找到相关公告" />
    </view>
  </view>
</view>
