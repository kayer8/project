.notice-search {
  padding: 0;
  --td-input-vertical-padding:20rpx;
}

.notice-search__input {
  border-radius: 16rpx;
  border: 2rpx solid #e5e9f0;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(31, 35, 41, 0.04);
}

.notice-search__input-element {
  min-height: 92rpx;
  padding: 0 32rpx 0 0;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1f2329;
}

.notice-search__icon {
  margin-left: 32rpx;
  margin-right: 18rpx;
  color: #6f8fbe;
  font-size: 34rpx;
}

.notice-search__clear {
  margin-right: 24rpx;
  color: #90a1b5;
}

.notice-card + .notice-card {
  margin-top: 20rpx;
}

.notice-card .record-row {
  align-items: flex-start;
  gap: 16rpx;
}

.notice-card__main {
  flex: 1;
  min-width: 0;
}

.notice-card .record-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-card__status {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 24rpx;
  position: relative;
}

.notice-card__status-tag {
  margin-right: 8rpx;
  flex-shrink: 0;
}

.notice-card__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e34d59;
  position:absolute;
  right: 0;
}

.notice-card__serial {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #5f6b7a;
}

.notice-card__body {
  margin-top: 12rpx;
  flex: 1;
  min-width: 0;
}

.notice-card__footer {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  position: relative;
}
