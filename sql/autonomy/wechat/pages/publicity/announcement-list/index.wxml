<view class="page-shell">
  <view class="card">
    <input class="text-input" placeholder="搜索公告标题" value="{{keyword}}" bindinput="handleKeywordInput" />
  </view>

  <view wx:for="{{records}}" wx:key="id" class="list-card" data-id="{{item.id}}" bindtap="handleOpenDetail">
    <view class="list-title">{{item.title}}</view>
    <view class="tag-row">
      <view wx:if="{{item.isPinned}}" class="pill pill-warning">置顶</view>
      <view class="pill">{{item.category}}</view>
    </view>
    <view class="list-desc">{{item.summary}}</view>
    <view class="list-meta">{{item.issuer}} · {{item.publishedAt}} · 已读 {{item.readCount}}</view>
  </view>
</view>
