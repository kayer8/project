.tab-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.tab-row {
  display: inline-flex;
  gap: 12rpx;
}

.tab-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  color: #52606d;
  font-size: 24rpx;
}

.tab-item-active {
  background: #0f4c5c;
  color: #ffffff;
}
