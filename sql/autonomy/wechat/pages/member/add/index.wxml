<view class="page-shell">
  <view wx:if="{{house}}" class="card">
    <view class="section-title">当前房屋</view>
    <view class="list-title">{{house.name}}</view>
    <view class="list-desc">{{house.groupName}} · 主角色 {{house.primaryRoleName}}</view>
  </view>

  <view class="form-card">
    <view class="field-block">
      <view class="field-label">添加方式</view>
      <picker mode="selector" range="{{addMethodOptions}}" value="{{addMethodIndex}}" data-field="addMethodIndex" bindchange="handlePickerChange">
        <view class="picker-field">{{addMethodOptions[addMethodIndex]}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">姓名</view>
      <input class="text-input" placeholder="请输入成员姓名" data-field="name" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">手机号</view>
      <input class="text-input" placeholder="请输入手机号" type="number" data-field="mobile" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">成员身份</view>
      <picker mode="selector" range="{{identityOptions}}" value="{{identityIndex}}" data-field="identityIndex" bindchange="handlePickerChange">
        <view class="picker-field">{{identityOptions[identityIndex]}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">与房屋关系</view>
      <picker mode="selector" range="{{relationOptions}}" value="{{relationIndex}}" data-field="relationIndex" bindchange="handlePickerChange">
        <view class="picker-field">{{relationOptions[relationIndex]}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">生效时间</view>
      <picker mode="date" value="{{form.startDate}}" data-field="startDate" bindchange="handleDateChange">
        <view class="picker-field">{{form.startDate}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">失效时间</view>
      <picker mode="date" value="{{form.endDate}}" data-field="endDate" bindchange="handleDateChange">
        <view class="picker-field">{{form.endDate || '可选'}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">查看账单权限</view>
      <switch checked="{{form.canViewBill}}" data-field="canViewBill" bindchange="handleSwitchChange" color="#0f4c5c" />
    </view>
    <view class="field-block">
      <view class="field-label">代办权限</view>
      <switch checked="{{form.canActAsAgent}}" data-field="canActAsAgent" bindchange="handleSwitchChange" color="#0f4c5c" />
    </view>
    <view class="field-block">
      <view class="field-label">参与意见征集</view>
      <switch checked="{{form.canJoinConsultation}}" data-field="canJoinConsultation" bindchange="handleSwitchChange" color="#0f4c5c" />
    </view>
    <view class="field-block">
      <view class="field-label">证明材料</view>
      <button class="secondary-button" bindtap="handleUploadMaterial">上传证明材料</button>
    </view>
  </view>

  <view class="button-row">
    <button class="primary-button" bindtap="handleSubmit">提交成员申请</button>
  </view>
</view>
