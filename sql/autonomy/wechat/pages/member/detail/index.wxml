<view class="page-shell" wx:if="{{detail}}">
  <view class="hero-panel">
    <view class="hero-title">{{detail.userName}}</view>
    <view class="hero-subtitle">{{detail.house.name}} · {{detail.identityType}} · {{detail.relationLabel}}</view>
  </view>

  <view class="card">
    <view class="info-row">
      <view class="info-label">手机号</view>
      <view class="info-value">{{detail.mobileMasked}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">当前状态</view>
      <view class="info-value">{{detail.statusLabel}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">生效时间</view>
      <view class="info-value">{{detail.effectiveAt}}</view>
    </view>
    <view wx:if="{{detail.expiredAt}}" class="info-row">
      <view class="info-label">失效时间</view>
      <view class="info-value">{{detail.expiredAt}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">权限与角色</view>
    <view class="tag-row">
      <view wx:if="{{detail.isPrimaryRole}}" class="pill pill-success">主角色</view>
      <view wx:if="{{detail.isVoteRepresentative}}" class="pill pill-warning">投票代表</view>
      <view wx:if="{{detail.isPayer}}" class="pill">主缴费人</view>
      <view wx:if="{{detail.canViewBill}}" class="pill">可查看账单</view>
      <view wx:if="{{detail.canActAsAgent}}" class="pill">可代办</view>
      <view wx:if="{{detail.canJoinConsultation}}" class="pill">可参与征集</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">历史记录</view>
    <view wx:for="{{detail.history}}" wx:key="time" class="info-row">
      <view class="info-label">{{item.time}}</view>
      <view class="info-value">{{item.content}}</view>
    </view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleOpenRepresentative">查看投票代表设置</button>
    <button class="secondary-button" bindtap="handleExtend">延长有效期</button>
    <button class="primary-button" bindtap="handleRemove">发起移除</button>
  </view>
</view>
