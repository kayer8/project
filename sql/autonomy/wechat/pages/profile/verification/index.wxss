.page-body {
  padding: 24rpx 24rpx 48rpx;
}

.verification-status {
  margin-bottom: 8rpx;
}

.verification-steps {
  display: grid;
  gap: 16rpx;
  margin-top: 16rpx;
}

.verification-step {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1px solid #e8edf3;
  background: #f8fafc;
}

.verification-step__index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #dfe9fb;
  color: #1f5fbf;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.verification-step__content {
  flex: 1;
}

.verification-step__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2329;
}

.verification-step__desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #5f6b7a;
}

.verification-upload-note {
  margin-bottom: 20rpx;
}
