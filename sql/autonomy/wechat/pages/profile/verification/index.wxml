<view class="page-shell">
  <app-navbar title="身份认证" />

  <view class="page-body">
    <view class="summary-banner">
      <view class="badge-row verification-status">
        <t-tag wx:if="{{verification.status === 'verified'}}" theme="success" variant="light">已通过</t-tag>
        <t-tag wx:elif="{{verification.status === 'pending'}}" theme="warning" variant="light">审核中</t-tag>
        <t-tag wx:else theme="danger" variant="light">待提交</t-tag>
        <t-tag theme="primary" variant="light">实名认证</t-tag>
      </view>
      <view class="icon-title-row">
        <t-icon name="user" size="48rpx" class="ui-icon ui-icon--primary" />
        <view class="summary-title">身份认证</view>
      </view>
      <view class="summary-desc">{{verification.status === 'verified' ? '当前账户已完成实名认证审核，可继续使用后续治理功能。' : '请按要求提交真实身份材料，审核结果将在此页持续展示。'}}</view>
    </view>

    <view class="section card info-card">
      <view class="icon-title-row">
        <t-icon name="view-list" size="40rpx" class="ui-icon ui-icon--primary" />
        <view class="section-title">认证流程</view>
      </view>
      <view class="verification-steps">
        <view class="verification-step">
          <view class="verification-step__index">1</view>
          <view class="verification-step__content">
            <view class="icon-inline-row">
              <t-icon name="user" size="32rpx" class="ui-icon" />
              <view class="verification-step__title">提交真实资料</view>
            </view>
            <view class="verification-step__desc">填写姓名、证件号码并上传证件照片，确保与物业备案资料一致。</view>
          </view>
        </view>
        <view class="verification-step">
          <view class="verification-step__index">2</view>
          <view class="verification-step__content">
            <view class="icon-inline-row">
              <t-icon name="time" size="32rpx" class="ui-icon ui-icon--warning" />
              <view class="verification-step__title">等待后台审核</view>
            </view>
            <view class="verification-step__desc">物业或管理人员将结合房屋资料与身份材料进行人工复核。</view>
          </view>
        </view>
        <view class="verification-step">
          <view class="verification-step__index">3</view>
          <view class="verification-step__content">
            <view class="icon-inline-row">
              <t-icon name="check-circle" size="32rpx" class="ui-icon ui-icon--success" />
              <view class="verification-step__title">查看认证结果</view>
            </view>
            <view class="verification-step__desc">认证结果将以“已通过 / 审核中 / 未通过”的状态持续展示。</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section card info-card">
      <view class="icon-title-row">
        <t-icon name="view-list" size="40rpx" class="ui-icon ui-icon--primary" />
        <view class="section-title">当前认证档案</view>
      </view>
      <view class="info-row">
        <view class="info-label">姓名</view>
        <view class="info-value">{{verification.name}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">证件号码</view>
        <view class="info-value">{{verification.idNo}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">认证时间</view>
        <view class="info-value">{{verification.verifiedAt}}</view>
      </view>
    </view>

    <view class="section page-note">当前账号已通过实名认证审核。如需变更身份信息，可以重新提交新的认证材料，原有记录将作为历史档案保留。</view>

    <view wx:if="{{!editing}}" class="section">
      <button class="secondary-button" bindtap="openEdit">重新提交认证材料</button>
    </view>

    <view wx:if="{{editing}}" class="section card form-card">
      <view class="field-block">
        <text class="field-label">真实姓名</text>
        <t-input
          t-class="td-input"
          t-class-input="td-input__element"
          borderless="{{true}}"
          clearable="{{true}}"
          placeholder="请输入真实姓名"
          value="{{realName}}"
          bind:change="handleNameInput"
        />
      </view>
      <view class="field-block">
        <text class="field-label">身份证号</text>
        <t-input
          t-class="td-input"
          t-class-input="td-input__element"
          borderless="{{true}}"
          maxlength="{{18}}"
          placeholder="请输入 18 位证件号"
          value="{{idNo}}"
          bind:change="handleIdInput"
        />
      </view>
      <view class="field-block">
        <text class="field-label">证件照片</text>
        <view class="action-row">
          <button class="secondary-button" data-field="frontImage" bindtap="chooseImage">上传人像面</button>
          <button class="secondary-button" data-field="backImage" bindtap="chooseImage">上传国徽面</button>
        </view>
        <view class="status-row section">
          <t-tag theme="{{frontImage ? 'success' : 'default'}}" variant="light">{{frontImage ? '人像面已上传' : '人像面未上传'}}</t-tag>
          <t-tag theme="{{backImage ? 'success' : 'default'}}" variant="light">{{backImage ? '国徽面已上传' : '国徽面未上传'}}</t-tag>
        </view>
      </view>
      <view class="page-note verification-upload-note">提交前请确认所填姓名、证件号码与上传照片清晰可辨，审核中如存在疑义将退回补充。</view>
      <button class="primary-button" bindtap="handleSubmit" disabled="{{!realName || idNo.length < 18 || !frontImage || !backImage}}">提交认证</button>
    </view>
  </view>
</view>
