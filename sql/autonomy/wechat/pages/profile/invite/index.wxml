<view class="page-shell">
  <app-navbar title="邀请成员" />

  <view class="page-body">
    <view class="card form-card">
      <view class="field-block">
        <text class="field-label">手机号</text>
        <input class="text-input" type="number" maxlength="11" placeholder="请输入成员手机号" value="{{phone}}" bindinput="handlePhoneInput" />
      </view>
      <view class="field-block">
        <text class="field-label">角色</text>
        <picker mode="selector" range="{{roles}}" value="{{roleIndex}}" bindchange="handleRoleChange">
          <view class="picker-field">{{roles[roleIndex]}}</view>
        </picker>
      </view>
      <view class="page-note">邀请发送后，对方使用手机号完成登录和确认，即可加入当前房屋。</view>
      <button class="primary-button section" bindtap="handleSubmit" disabled="{{phone.length < 11}}">发送邀请</button>
    </view>
  </view>
</view>
