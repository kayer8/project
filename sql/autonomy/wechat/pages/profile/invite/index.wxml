<view class="page-shell">
  <app-navbar title="邀请成员" />

  <view class="page-body">
    <view class="card form-card">
      <view class="icon-title-row">
        <t-icon name="mail" size="40rpx" class="ui-icon ui-icon--primary" />
        <view class="section-title">邀请成员</view>
      </view>
      <view class="field-block">
        <text class="field-label">手机号</text>
        <t-input
          t-class="td-input"
          t-class-input="td-input__element"
          borderless="{{true}}"
          type="number"
          maxlength="{{11}}"
          placeholder="请输入成员手机号"
          value="{{phone}}"
          bind:change="handlePhoneInput"
        />
      </view>
      <view class="field-block">
        <text class="field-label">角色</text>
        <t-radio-group
          options="{{roleOptions}}"
          value="{{selectedRole}}"
          icon="line"
          placement="right"
          bind:change="handleRoleChange"
        />
      </view>
      <view class="page-note">邀请发送后，对方使用手机号完成登录和确认，即可加入当前房屋。</view>
      <button class="primary-button section" bindtap="handleSubmit" disabled="{{phone.length < 11}}">发送邀请</button>
    </view>
  </view>
</view>
