<app-navbar title="我的投票记录" />

<view class="page-body">
  <view class="card info-card profile-vote-intro">
    <view class="icon-title-row">
      <t-icon name="check-circle" size="40rpx" class="ui-icon ui-icon--primary" />
      <view class="record-title">已参与的投票</view>
    </view>
    <view class="record-note">这里只展示你已经提交过的投票，点击可查看自己的投票详情。</view>
  </view>

  <view class="section section--fill">
    <app-list
      list="{{votes}}"
      loading="{{loading}}"
      showLoading="{{true}}"
      isLoadMore="{{isLoadMore}}"
      finished="{{finished}}"
      emptyDescription="暂无投票记录"
      content-class="list-content"
      bind:refresh="onListRefresh"
      bind:loadMore="onListLoadMore"
    >
      <view wx:if="{{errorMessage}}" class="section page-note page-note--warning">{{errorMessage}}</view>

      <view
        wx:for="{{votes}}"
        wx:key="id"
        class="record-card vote-record"
        data-id="{{item.id}}"
        bindtap="openVoteDetail"
      >
        <view class="record-row">
          <view>
            <view class="icon-inline-row">
              <view class="record-title">{{item.title}}</view>
            </view>
            <view class="record-note">发起方：{{item.sponsor}} 路 截止 {{item.deadlineLabel}}</view>
          </view>
          <view class="badge-row">
            <t-tag theme="{{item.status === 'ONGOING' ? 'primary' : 'default'}}" variant="light">
              {{item.statusLabel}}
            </t-tag>
            <t-tag theme="warning" variant="light">{{item.typeLabel}}</t-tag>
            <t-tag theme="success" variant="light">已投票</t-tag>
          </view>
        </view>

        <view class="vote-record__meta">
          <view class="vote-record__meta-item">我的选择：{{item.selectedOptionText}}</view>
          <view class="vote-record__meta-item">参与情况：{{item.participantCount}} / {{item.totalHouseholds}}</view>
        </view>
        <view class="list-desc">{{item.description || '暂无投票说明'}}</view>
      </view>
    </app-list>
  </view>
</view>
