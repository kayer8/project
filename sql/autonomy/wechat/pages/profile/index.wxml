<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-top">
      <view>
        <view class="hero-title">{{profile.nickname}}</view>
        <view class="hero-subtitle">{{profile.communityName}} 路 {{profile.currentIdentityLabel}}</view>
      </view>
      <view class="pill pill-success">{{profile.authStatusLabel}}</view>
    </view>
  </view>

  <view class="card">
    <view class="info-row">
      <view class="info-label">当前房屋</view>
      <view class="info-value">{{currentHouse ? currentHouse.name : '暂未绑定房屋'}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">住户组</view>
      <view class="info-value">{{currentHouse ? currentHouse.groupName : '暂无住户组'}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">消息未读</view>
      <view class="info-value">{{profile.unreadCount}} 条</view>
    </view>
  </view>

  <view
    wx:for="{{shortcuts}}"
    wx:key="title"
    class="list-card"
    data-path="{{item.path}}"
    data-type="{{item.type}}"
    bindtap="handleOpenShortcut"
  >
    <view class="list-title">{{item.title}}</view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleCallManager">联系管理员</button>
  </view>
</view>
