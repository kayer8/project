<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">{{typeLabel}}</view>
    <view class="hero-subtitle">当前审核状态：{{result.statusLabel}}</view>
  </view>

  <view class="card">
    <view class="info-row">
      <view class="info-label">提交时间</view>
      <view class="info-value">{{result.submittedAt}}</view>
    </view>
    <view wx:if="{{result.reviewedAt}}" class="info-row">
      <view class="info-label">审核时间</view>
      <view class="info-value">{{result.reviewedAt}}</view>
    </view>
    <view wx:if="{{result.rejectReason}}" class="info-row">
      <view class="info-label">驳回原因</view>
      <view class="info-value">{{result.rejectReason}}</view>
    </view>
  </view>

  <view class="button-row">
    <button wx:if="{{result.statusLabel === '已驳回'}}" class="secondary-button" bindtap="handleResubmit">重新提交</button>
    <button class="primary-button" bindtap="handleBackHome">返回首页</button>
  </view>
</view>
