<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">请选择当前要申请的身份</view>
    <view class="hero-subtitle">当前账号身份：{{profile.currentIdentityLabel}} · 认证状态：{{profile.authStatusLabel}}</view>
  </view>

  <view class="card tip-card">
    <view class="list-title">提交前说明</view>
    <view class="list-desc">一套房屋可存在多个成员，但主角色与正式表决资格以后端审核结果为准。</view>
    <view class="section-link" bindtap="handleOpenRules">查看认证规则</view>
  </view>

  <view
    wx:for="{{identityCards}}"
    wx:key="type"
    class="card identity-card"
    data-path="{{item.path}}"
    bindtap="handleSelect"
  >
    <view class="list-title">{{item.title}}</view>
    <view class="list-desc">{{item.desc}}</view>
  </view>
</view>
