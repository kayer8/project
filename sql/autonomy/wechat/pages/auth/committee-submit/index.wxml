<view class="page-shell">
  <view class="form-card">
    <view class="field-block">
      <view class="field-label">姓名</view>
      <input class="text-input" placeholder="请输入真实姓名" data-field="name" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">手机号</view>
      <input class="text-input" placeholder="请输入手机号" type="number" data-field="mobile" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">职务</view>
      <input class="text-input" placeholder="例如 社区委员 / 楼栋联络员" data-field="title" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">所属楼栋或负责片区</view>
      <input class="text-input" placeholder="例如 2栋至4栋" data-field="area" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">任命证明</view>
      <button class="secondary-button" bindtap="handleUploadAppointment">上传任命证明</button>
    </view>
    <view class="field-block">
      <view class="field-label">社区确认材料</view>
      <button class="secondary-button" bindtap="handleUploadCommunityConfirm">上传社区确认材料</button>
    </view>
    <view class="field-block">
      <view class="field-label">备注</view>
      <textarea class="text-area" placeholder="可说明负责工作范围" data-field="note" bindinput="handleInput"></textarea>
    </view>
    <view class="info-row">
      <view class="info-label">同意协议</view>
      <switch checked="{{form.agreed}}" bindchange="handleAgreeChange" color="#0f4c5c" />
    </view>
  </view>

  <view class="button-row">
    <button class="primary-button" bindtap="handleSubmit">提交认证</button>
  </view>
</view>
