<view class="page-shell">
  <view wx:for="{{sections}}" wx:key="title" class="card">
    <view class="section-title">{{item.title}}</view>
    <view wx:for="{{item.rules}}" wx:key="*this" class="info-row">
      <view class="info-label">规则</view>
      <view class="info-value">{{item}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">统一说明</view>
    <view wx:for="{{reminders}}" wx:key="*this" class="info-row">
      <view class="info-label">提示</view>
      <view class="info-value">{{item}}</view>
    </view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleCallManager">联系管理员</button>
  </view>
</view>
