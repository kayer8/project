<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">物业自治居民端</view>
    <view class="hero-subtitle">
      {{step === 'login' ? '先完成微信登录，已有账号会直接进入首页。' : '检测到首次进入，请补全手机号完成注册。'}}
    </view>
  </view>

  <view class="card auth-card">
    <view class="section-title">{{step === 'login' ? '微信快捷登录' : '完善注册信息'}}</view>

    <view wx:if="{{profile.avatarUrl}}" class="profile-preview">
      <image class="profile-avatar" src="{{profile.avatarUrl}}" mode="aspectFill" />
      <view>
        <view class="list-title">{{profile.nickname}}</view>
        <view class="muted-text">将用于创建当前微信账号</view>
      </view>
    </view>

    <view wx:if="{{step === 'register'}}" class="field-block">
      <view class="field-label">手机号</view>
      <input
        class="text-input"
        type="number"
        maxlength="20"
        placeholder="请输入常用手机号"
        value="{{mobile}}"
        data-field="mobile"
        bindinput="handleInput"
      />
      <view class="field-hint">当前后端注册接口使用手动输入手机号，不走微信手机号解密。</view>
    </view>

    <view class="button-row">
      <button
        wx:if="{{step === 'login'}}"
        class="primary-button"
        loading="{{submitting}}"
        bindtap="handleWechatLogin"
      >
        微信授权登录
      </button>
      <button
        wx:else
        class="primary-button"
        loading="{{submitting}}"
        bindtap="handleRegister"
      >
        完成注册
      </button>
    </view>

    <view wx:if="{{step === 'register'}}" class="button-row">
      <button class="secondary-button" bindtap="handleBackToLogin">返回重新登录</button>
    </view>
  </view>
</view>
