<view class="page-shell">
  <view class="form-card">
    <view class="field-block">
      <view class="field-label">姓名</view>
      <input class="text-input" placeholder="请输入真实姓名" data-field="name" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">手机号</view>
      <input class="text-input" placeholder="请输入手机号" type="number" data-field="mobile" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">身份证后四位</view>
      <input class="text-input" placeholder="用于审核比对" type="number" maxlength="4" data-field="idLast4" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">楼栋</view>
      <input class="text-input" placeholder="例如 2栋" data-field="building" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">单元</view>
      <input class="text-input" placeholder="例如 1单元" data-field="unit" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">房号</view>
      <input class="text-input" placeholder="例如 1202" data-field="room" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">房屋关系</view>
      <picker mode="selector" range="{{relationOptions}}" value="{{relationIndex}}" bindchange="handleRelationChange">
        <view class="picker-field">{{relationOptions[relationIndex]}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">证明材料</view>
      <button class="secondary-button" bindtap="handleUploadMaterial">上传房屋证明或授权资料</button>
    </view>
    <view class="field-block">
      <view class="field-label">补充说明</view>
      <textarea class="text-area" placeholder="可填写家庭成员关系或代理说明" data-field="note" bindinput="handleInput"></textarea>
    </view>
    <view class="info-row">
      <view class="info-label">同意协议</view>
      <switch checked="{{form.agreed}}" bindchange="handleAgreeChange" color="#0f4c5c" />
    </view>
    <view class="field-hint">提交后将进入人工审核，主角色和投票资格以后端审核结果为准。</view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleSaveDraft">保存草稿</button>
    <button class="primary-button" bindtap="handleSubmit">提交认证</button>
  </view>
</view>
