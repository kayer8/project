<view class="page-shell">
  <view class="form-card">
    <view class="field-block">
      <view class="field-label">姓名</view>
      <input class="text-input" placeholder="请输入真实姓名" data-field="name" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">手机号</view>
      <input class="text-input" placeholder="请输入手机号" type="number" data-field="mobile" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">楼栋</view>
      <input class="text-input" placeholder="例如 5栋" data-field="building" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">单元</view>
      <input class="text-input" placeholder="例如 2单元" data-field="unit" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">房号</view>
      <input class="text-input" placeholder="例如 803" data-field="room" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">租住起始日期</view>
      <picker mode="date" value="{{form.startDate}}" data-field="startDate" bindchange="handleDateChange">
        <view class="picker-field">{{form.startDate}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">租住结束日期</view>
      <picker mode="date" value="{{form.endDate}}" data-field="endDate" bindchange="handleDateChange">
        <view class="picker-field">{{form.endDate}}</view>
      </picker>
    </view>
    <view class="field-block">
      <view class="field-label">房东姓名</view>
      <input class="text-input" placeholder="可选" data-field="ownerName" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">房东手机号</view>
      <input class="text-input" placeholder="可选" type="number" data-field="ownerMobile" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">居住人数</view>
      <input class="text-input" placeholder="可选" type="number" data-field="residentCount" bindinput="handleInput" />
    </view>
    <view class="field-block">
      <view class="field-label">租赁资料</view>
      <button class="secondary-button" bindtap="handleUploadMaterial">上传租赁合同或授权证明</button>
    </view>
    <view class="field-block">
      <view class="field-label">备注</view>
      <textarea class="text-area" placeholder="可补充租住说明" data-field="note" bindinput="handleInput"></textarea>
    </view>
    <view class="info-row">
      <view class="info-label">同意协议</view>
      <switch checked="{{form.agreed}}" bindchange="handleAgreeChange" color="#0f4c5c" />
    </view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleSaveDraft">保存草稿</button>
    <button class="primary-button" bindtap="handleSubmit">提交认证</button>
  </view>
</view>
