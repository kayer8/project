  <app-navbar title="髢ｭ蟀壼匚豬懈資蟋ｩ" />

  <view class="page-body">
    <view class="section section--fill">
      <app-list
        list="{{posts}}"
        loading="{{loading}}"
        showLoading="{{true}}"
        isLoadMore="{{isLoadMore}}"
        finished="{{finished}}"
        bind:refresh="onListRefresh"
        bind:loadMore="onListLoadMore"
      >
        <view wx:for="{{posts}}" wx:key="title" class="record-card">
          <view class="icon-inline-row">
            <t-icon name="notification" size="32rpx" class="ui-icon" />
            <view class="record-title">{{item.title}}</view>
          </view>
          <view class="record-note">{{item.note}}</view>
        </view>
      </app-list>
    </view>
    <view class="section action-row">
      <button class="primary-button">骰呎嬥遶ｷ迺勤ｿ駒平</button>
      <button class="secondary-button">髀後Ι貉ɾｨｲ隸ｲ蟋ｩ</button>
    </view>
  </view>
