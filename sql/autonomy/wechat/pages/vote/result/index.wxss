.result-card {
  margin-top: 20rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.result-value {
  color: #486581;
  font-size: 24rpx;
}

.result-bar {
  overflow: hidden;
  height: 16rpx;
  margin: 16rpx 0 12rpx;
  border-radius: 999rpx;
  background: #d9e2ec;
}

.result-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f4c5c, #2b7a78);
}
