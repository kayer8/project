<view class="page-shell" wx:if="{{vote}}">
  <view class="hero-panel">
    <view class="hero-title">{{vote.title}}</view>
    <view class="hero-subtitle">{{vote.statusLabel}} · 共 {{totalVotes}} 票</view>
  </view>

  <view wx:if="{{vote.allowRealtimeResult || vote.status === 'ENDED'}}" class="card">
    <view class="info-row">
      <view class="info-label">投票方式</view>
      <view class="info-value">{{vote.modeLabel}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">统计范围</view>
      <view class="info-value">{{vote.scopeLabel}}</view>
    </view>
    <view wx:for="{{vote.options}}" wx:key="id" class="result-card">
      <view class="result-head">
        <view class="list-title">{{item.title}}</view>
        <view class="result-value">{{item.count}} 票 · {{item.ratio}}</view>
      </view>
      <view class="result-bar">
        <view class="result-bar-fill" style="width: {{item.ratio}};"></view>
      </view>
      <view class="list-desc">{{item.description}}</view>
    </view>
  </view>
  <view wx:else class="empty-block">当前投票不开放实时结果，待结束后再查看。</view>
</view>
