<view class="page-shell" wx:if="{{vote}}">
  <view class="hero-panel">
    <view class="hero-title">{{vote.title}}</view>
    <view class="hero-subtitle">{{vote.initiator}} · {{vote.statusLabel}}</view>
  </view>

  <view class="card">
    <view class="tag-row">
      <view class="pill">{{vote.typeLabel}}</view>
      <view class="pill">{{vote.modeLabel}}</view>
      <view class="pill pill-warning">{{vote.houseName}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">投票范围</view>
      <view class="info-value">{{vote.scopeLabel}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">时间区间</view>
      <view class="info-value">{{vote.startAt}} 至 {{vote.endAt}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">我的状态</view>
      <view class="info-value">{{vote.myStatusLabel}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">投票说明</view>
    <view class="list-desc">{{vote.description}}</view>
    <view wx:for="{{vote.rules}}" wx:key="*this" class="info-row">
      <view class="info-label">规则</view>
      <view class="info-value">{{item}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">选项预览</view>
    <view wx:for="{{vote.options}}" wx:key="id" class="list-card">
      <view class="list-title">{{item.title}}</view>
      <view class="list-desc">{{item.description}}</view>
      <view class="list-meta">当前统计 {{item.count}} 票 · {{item.ratio}}</view>
    </view>
  </view>

  <view class="button-row">
    <button wx:if="{{vote.canVote && vote.status === 'ONGOING'}}" class="primary-button" bindtap="handleJoinVote">立即投票</button>
    <button wx:if="{{vote.allowRealtimeResult || vote.status === 'ENDED'}}" class="secondary-button" bindtap="handleOpenResult">查看结果</button>
    <button class="secondary-button" bindtap="handleShare">分享给相关住户</button>
  </view>
</view>
