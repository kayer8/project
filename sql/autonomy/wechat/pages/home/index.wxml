<view class="page-shell home-shell">
  <view hidden="{{activeTab !== 'disclosure'}}">
    <disclosure-panel />
  </view>
  <view hidden="{{activeTab !== 'voting'}}">
    <voting-panel />
  </view>
  <view hidden="{{activeTab !== 'profile'}}">
    <profile-panel active="{{activeTab === 'profile'}}" />
  </view>

  <app-tabbar value="{{activeTab}}" mode="switch" bindtabchange="handleTabChange" />
</view>
