<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">居民首页</view>
    <view class="hero-subtitle">当前首页只承接注册结果与认证状态，后续业务能力会继续补齐。</view>
  </view>

  <view wx:if="{{loading}}" class="section card empty-block">正在加载账号状态…</view>

  <view wx:elif="{{errorMessage}}" class="section card form-card">
    <view class="list-desc">{{errorMessage}}</view>
    <button class="primary-button home-action" bindtap="handleRelogin">重新登录</button>
  </view>

  <block wx:else>
    <view class="section card info-card" wx:if="{{user}}">
      <view class="section-head">
        <view class="section-title">{{user.realName || user.nickname || '微信用户'}}</view>
        <view class="pill {{user.residentStatus === 'SYNCED' ? 'pill-success' : 'pill-warning'}}">
          {{statusText}}
        </view>
      </view>
      <view class="info-row">
        <text class="info-label">手机号</text>
        <text class="info-value">{{user.mobile || '未获取'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">账号状态</text>
        <text class="info-value">{{user.status}}</text>
      </view>
      <view class="info-row" wx:if="{{user.latestRegistrationRequest}}">
        <text class="info-label">已提交信息</text>
        <text class="info-value">
          {{user.latestRegistrationRequest.buildingName || '未选择楼栋'}}
          {{user.latestRegistrationRequest.houseDisplayName || ''}}
        </text>
      </view>
    </view>

    <view class="section card info-card" wx:if="{{user && user.residentStatus === 'UNVERIFIED'}}">
      <view class="section-title">待审核</view>
      <view class="list-desc">
        你的楼栋房屋信息已经提交，当前是未认证状态。审核通过后，会自动同步房屋和成员能力。
      </view>
    </view>

    <view class="section card info-card" wx:if="{{houses.length}}">
      <view class="section-title">已同步房屋</view>
      <block wx:for="{{houses}}" wx:key="houseId">
        <view class="info-row">
          <text class="info-label">{{item.buildingName}}</text>
          <text class="info-value">{{item.displayName}} · {{item.relationLabel}}</text>
        </view>
      </block>
    </view>

    <view class="section card form-card">
      <button class="secondary-button" bindtap="handleRelogin">退出并重新登录</button>
    </view>
  </block>
</view>
