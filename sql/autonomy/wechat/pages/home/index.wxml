
<view class="home-page">
  <view class="home-panels">
    <view hidden="{{activeTab !== 'disclosure'}}" class="home-panel">
      <disclosure-panel class="home-panel" />
    </view>
    <view hidden="{{activeTab !== 'voting'}}" class="home-panel">
      <voting-panel class="home-panel" />
    </view>
    <view hidden="{{activeTab !== 'profile'}}" class="home-panel">
      <profile-panel active="{{activeTab === 'profile'}}" class="home-panel" />
    </view>
  </view> 
  

  <app-tabbar value="{{activeTab}}" mode="switch" bindtabchange="handleTabChange" />
</view>
