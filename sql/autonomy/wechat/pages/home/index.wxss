.house-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.house-summary__title {
  font-size: 42rpx;
  font-weight: 700;
}

.house-summary__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.section-card {
  padding: 24rpx;
}

.popup-panel {
  padding: 32rpx 24rpx 48rpx;
  background: #ffffff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #17212b;
  margin-bottom: 24rpx;
}

.popup-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7fafc;
  border: 1px solid transparent;
  margin-bottom: 16rpx;
}

.popup-item--active {
  border-color: #0f4c5c;
  background: #e8f5f8;
}
