.page {
  padding: 32rpx;
}

.hero {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #0f766e, #155e75);
  color: #ffffff;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-item {
  padding: 24rpx;
}

.section-name {
  font-size: 30rpx;
  font-weight: 600;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5f6b7a;
}
