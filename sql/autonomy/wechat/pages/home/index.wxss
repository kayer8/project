.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.message-entry {
  position: relative;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
}

.message-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: #ffd166;
  color: #1f2933;
  font-size: 20rpx;
  text-align: center;
}

.hero-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.current-house {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
}

.current-house-name {
  font-size: 30rpx;
  font-weight: 600;
}

.current-house-action {
  color: #ffd166;
  font-size: 26rpx;
  font-weight: 600;
}

.stat-value-small {
  font-size: 26rpx;
  line-height: 1.4;
}
