.register-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.14), transparent 34%),
    linear-gradient(180deg, #f5f8ff 0%, #f3f5f8 26%, #eef2f6 100%);
}

.register-hero {
  padding: 36rpx 32rpx 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #fefefe 0%, #f1f6ff 100%);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.register-hero__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #2456c2;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.register-hero__title {
  margin-top: 22rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #152033;
}

.register-hero__desc {
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #5f6c82;
}

.register-steps {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 28rpx;
}

.register-step {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(204, 216, 236, 0.72);
}

.register-step__index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #2b67d8;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.register-step__text {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #334155;
}

.register-card,
.register-summary {
  margin-top: 24rpx;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
}

.register-card__header {
  margin-bottom: 10rpx;
}

.register-card__title,
.register-summary__title {
  font-size: 31rpx;
  font-weight: 700;
  color: #162033;
}

.register-card__subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6b778c;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx 16rpx;
}

.form-field {
  margin-top: 24rpx;
}

.form-field--full {
  grid-column: 1 / -1;
}

.form-field__label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #344256;
}

.form-field__hint {
  margin-top: 12rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #7a8597;
}

.selector-field,
.register-input {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
  border: 1px solid #e2e8f0;
}

.selector-field--disabled {
  opacity: 0.6;
}

.selector-field__text {
  flex: 1;
  font-size: 28rpx;
  color: #94a3b8;
}

.selector-field__text--selected {
  color: #162033;
}

.selector-field__icon {
  color: #94a3b8;
}

.register-input__element {
  font-size: 28rpx !important;
  color: #162033 !important;
}

.register-summary__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.register-summary__label {
  font-size: 24rpx;
  color: #6b778c;
}

.register-summary__value {
  flex: 1;
  text-align: right;
  font-size: 25rpx;
  color: #162033;
  line-height: 1.6;
}

.register-action {
  margin-top: 28rpx;
}

.register-action__hint {
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a8597;
}

.register-action__link {
  color: #2964d9;
}
