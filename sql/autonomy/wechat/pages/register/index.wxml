  <app-navbar title="绑定房屋" left-arrow="{{true}}" />

  <view class="page-body">
    <view wx:if="{{phase === 'phone'}}" class="section card form-card">
      <view class="icon-title-row">
        <t-icon name="user" size="40rpx" class="ui-icon ui-icon--primary" />
        <view class="section-title">第一步：手机号核验</view>
      </view>
      <button
        class="primary-button section"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        loading="{{submitting}}"
      >
        微信授权手机号
      </button>
      <view class="register-link-row">
        <text class="muted-text">继续即表示你已阅读并同意</text>
        <text class="section-link" bindtap="openPrivacy">《隐私政策》</text>
      </view>
    </view>

    <view wx:if="{{phase === 'form'}}" class="section card form-card">
      <view class="icon-title-row">
        <t-icon name="home" size="40rpx" class="ui-icon ui-icon--primary" />
        <view class="section-title">第二步：补充房屋信息</view>
      </view>

      <view class="field-block">
        <text class="field-label">手机号</text>
        <view class="text-input static-field">{{mobileMasked}}</view>
        <view wx:if="{{syncMessage}}" class="field-hint">{{syncMessage}}</view>
      </view>

      <view class="field-block">
        <text class="field-label">楼栋</text>
        <view class="picker-field" bindtap="openBuildingPicker">{{selectedBuildingName || '请选择楼栋'}}</view>
      </view>

      <view class="field-block">
        <text class="field-label">房屋</text>
        <view class="picker-field" bindtap="openHousePicker">{{selectedHouseName || '请选择房屋'}}</view>
      </view>

      <button class="primary-button section" bindtap="handleSubmitRequest" loading="{{submitting}}">
        提交楼栋信息
      </button>
    </view>
  </view>

  <t-picker
    visible="{{buildingPickerVisible}}"
    title="选择楼栋"
    value="{{buildingPickerValue}}"
    bind:confirm="handleBuildingConfirm"
    bind:cancel="closeBuildingPicker"
    bind:visible-change="handleBuildingPickerVisibleChange"
  >
    <t-picker-item options="{{buildingPickerOptions}}" />
  </t-picker>

  <t-picker
    visible="{{housePickerVisible}}"
    title="选择房屋"
    value="{{housePickerValue}}"
    bind:confirm="handleHouseConfirm"
    bind:cancel="closeHousePicker"
    bind:visible-change="handleHousePickerVisibleChange"
  >
    <t-picker-item options="{{housePickerOptions}}" />
  </t-picker>
