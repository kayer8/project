page {
  background: #f3f5f7;
  color: #1f2329;
  font-family: 'PingFang SC', 'Segoe UI', sans-serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

t-input,
t-textarea,
t-radio-group,
t-picker,
t-date-time-picker {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.page-body {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  min-height: 0;
}



.section--fill {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  min-height: 0;
}

.hero-panel,
.summary-banner {
  padding: 28rpx 26rpx;
  border-radius: 20rpx;
  border: 1px solid #dce5f2;
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
  box-shadow: none;
}

.hero-title,
.summary-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #1f2329;
}

.hero-subtitle,
.summary-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #5f6b7a;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  border: 1px solid #e4e8ef;
  box-shadow: none;
}

.section {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #1f2329;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1.62;
}

.section-link {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f5fbf;
}

.icon-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-inline-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.icon-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ui-icon {
  color: #999999;
  flex-shrink: 0;
}

.ui-icon--primary {
  color: #2b5aed;
}

.ui-icon--success {
  color: #2ba471;
}

.ui-icon--warning {
  color: #fa8c16;
}

.ui-icon--danger {
  color: #e34d59;
}

.ui-icon--lg {
  font-size: 48rpx;
}

.ui-icon--md {
  font-size: 40rpx;
}

.ui-icon--sm {
  font-size: 32rpx;
}

.status-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5f6b7a;
}

.status-hint + .status-hint {
  margin-top: 8rpx;
}

.muted-text {
  color: #86909c;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  border: 1px solid #d7e4fb;
  background: #f4f8ff;
  color: #1f5fbf;
}

.pill-warning {
  border-color: #f3dfbd;
  background: #fff7eb;
  color: #a16910;
}

.pill-success {
  border-color: #d2ead8;
  background: #eff8f1;
  color: #1d6f42;
}

.pill-danger {
  border-color: #f2d4d4;
  background: #fff1f0;
  color: #b42318;
}

.grid-2,
.grid-4 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.metric-card,
.stat-card {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1px solid #e4e8ef;
}

.metric-label,
.stat-label {
  font-size: 22rpx;
  color: #86909c;
}

.metric-value,
.stat-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f5fbf;
}

.metric-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #86909c;
  line-height: 1.5;
}

.list-card {
  padding: 24rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #1f2329;
}

.list-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #86909c;
  font-size: 23rpx;
}

.list-desc {
  margin-top: 12rpx;
  color: #4e5969;
  font-size: 25rpx;
  line-height: 1.72;
}

.record-card {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1px solid #e8edf3;
  box-shadow: none;
}
.record-card + .record-card {
  margin-top: 16rpx;
}

.record-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.record-title {
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #1f2329;
}

.record-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.62;
  color: #86909c;
}

.badge-row,
.tag-row,
.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-row .primary-button,
.action-row .secondary-button,
.action-row .ghost-button,
.action-row .nav-button {
  flex: 1;
}

.action-button {
  padding: 24rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1px solid #e4e8ef;
  box-shadow: none;
}

.action-title {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #1f2329;
}

.action-desc {
  margin-top: 8rpx;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1.62;
}

.info-card,
.form-card {
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid #edf1f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #86909c;
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 25rpx;
  line-height: 1.62;
  color: #1f2329;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-field {
  padding: 0;
  --td-input-vertical-padding: 20rpx;
}

.search-field__input {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 0;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid #e5e9f0;
  overflow: hidden;
}

.search-field__input-element {
  box-sizing: border-box;
  width: 100%;
  min-height: 92rpx;
  padding: 0 32rpx 0 0;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1f2329;
  background: transparent;
}

.search-field__icon {
  margin-left: 16rpx;
  color: #6f8fbe;
  font-size: 34rpx;
}

.search-field__clear {
  margin-right: 24rpx;
  color: #90a1b5;
}

.toolbar-input,
.td-input,
.td-textarea {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 0;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1px solid #d7dee8;
  overflow: hidden;
}

.toolbar-input__element,
.td-input__element,
.td-textarea__element {
  box-sizing: border-box;
  width: 100%;
  color: #1f2329;
  background: transparent;
}

.toolbar-input__element,
.td-input__element {
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.td-textarea__element {
  min-height: 180rpx;
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.72;
}

.field-block {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2329;
}

.field-hint {
  margin-top: 8rpx;
  color: #86909c;
  font-size: 22rpx;
  line-height: 1.6;
}

.text-input,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx 22rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1px solid #d7dee8;
  font-size: 26rpx;
  color: #1f2329;
  box-sizing: border-box;
}

.static-field {
  display: flex;
  align-items: center;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.primary-button,
.secondary-button,
.ghost-button,
.nav-button {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 86rpx;
  text-align: center;
}

.primary-button {
  background: #1f5fbf;
  border: 1px solid #1f5fbf;
  color: #ffffff;
}

.secondary-button {
  background: #ffffff;
  border: 1px solid #cad7eb;
  color: #1f5fbf;
}

.ghost-button,
.nav-button {
  background: #f6f8fb;
  border: 1px solid #e1e7f0;
  color: #4e5969;
}

button[disabled] {
  background: #e8edf3 !important;
  border-color: #e8edf3 !important;
  color: #a5acb8 !important;
}

.page-note {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1px solid #d8e4f5;
  background: #f4f8ff;
  color: #35527a;
  font-size: 23rpx;
  line-height: 1.72;
}

.page-note--warning {
  border-color: #f4dfbf;
  background: #fff7eb;
  color: #a16910;
}

.page-note--success {
  border-color: #d3ebd9;
  background: #eff8f1;
  color: #1d6f42;
}

.house-switch {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
}

.safe-bottom-space {
  height: 40rpx;
}

.empty-block {
  padding: 40rpx 24rpx;
  text-align: center;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1.7;
}
